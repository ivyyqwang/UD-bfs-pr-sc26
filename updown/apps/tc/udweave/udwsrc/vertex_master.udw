            count = count - 1;
            if(count == 0){
                send_event(cont, count, IGNRCONT);
                yield_terminate;
            }
            yield;
        }
        lmbuff[NUM_INT] = num_int;
        count = count - 1;
        if(count == 0){
            send_event(cont, count, IGNRCONT);
            yield_terminate;
        }
    }
}
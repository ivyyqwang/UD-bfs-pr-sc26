                count = count - 1;
                if(count == 0){
                    send_event(cont, count, IGNRCONT);
                    yield_terminate;
                }
                yield;
            }
            addr = addr + 8;
        }else{
            lmbuff[NUM_INT] = num_int;
            count = count - 1;
            if(count == 0){
                send_event(cont, count, IGNRCONT);
                yield_terminate;
            }
            yield;
        }
        if(addr < nl_ptr_end){
            long v2 = op5;
            if(v1 > v2){
                num_int = num_int + 1;

                // next_nwid = hash(v1, hash(v2, HASH_SEED))
                unsigned int next_nwid = HASH_SEED;
                asm{

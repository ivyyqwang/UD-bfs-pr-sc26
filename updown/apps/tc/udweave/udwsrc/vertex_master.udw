// This is all metadata information
#include "v1v2intersection.udwh"
#include "intersection_launchers.udwh"
#include "flag.udwh"
#include "common.udwh"


#define HASH_SEED 0

thread vertex_master {
    unsigned long v1;
    unsigned long cont;
    unsigned long count;
    long* nl_ptr_end;
    long* local lmbuff;
    long* local temp_lmbuff;

    event launch (long* _g_v, long _v1){ 
#ifdef DEBUG
        print("[DEBUG][NWID %lu] <vertex_master> inputs g_v:%lu, v1:%lu, thread:%lu", NETID, g_v, v1, TID);
#endif
        v1 = _v1;
        cont = CCONT;

        // Fetch V1 8 bytes from g_v[v1]
        long *v_ptr = _g_v + (v1 << 6);
#ifdef DEBUG        
        print("[DEBUG][NWID %lu] Fetching v1:0x%lX", NETID, v_ptr);
#endif
		send_dram_read(v_ptr, 5, v1_return);
        yield;
    }

    event v1_return(unsigned long op0, unsigned long op1, unsigned long op2, unsigned long _min_vid, unsigned long _max_vid){
        //deg, id, neigh,
        if(op0 <= 1)
        { 
            // thread can be returned to master_launcher 
            send_event(cont, op0, IGNRCONT);
#ifdef DEBUG        
            print("[DEBUG][NWID :%lu]Terminate v:%lu because vertex deg:%lu", NETID, op1, op0);
#endif
            yield_terminate;
        }
        lmbuff = LMBASE;
        temp_lmbuff = LMBASE + (SENDBUFFER << 3);
        count = 0;
        temp_lmbuff[0] = v1;
        temp_lmbuff[3] = NETID;

        // if(op0 == 1){
        //     long v2 = _min_vid;
        //     unsigned long num_int = lmbuff[NUM_INT];
        //     long num_total_lanes = lmbuff[NUM_LANES_TOTAL];
            
        //     if(v1 > v2){
        //         num_int = num_int + 1;

        //         // next_nwid = hash(v1, hash(v2, HASH_SEED))
        //         unsigned int next_nwid = HASH_SEED;
        //         asm{
        //             "hash %[src] %[dst]"
        //         }: [src] "r" (v2), [dst] "r" (next_nwid);
        //         asm{
        //             "hash %[src] %[dst]"
        //         }: [src] "r" (v1), [dst] "r" (next_nwid);
        //         next_nwid = next_nwid & num_total_lanes;  // next_nwid = next_nwid % total_lanes
        //         unsigned long evword = evw_new(next_nwid, intersection_launcher__send_to_worker_thread4);

        //         temp_lmbuff[1] = v2;
        //         temp_lmbuff[2] = v2;
        //         send_event(evword, temp_lmbuff, 4, IGNRCONT);
        //     }
        //     lmbuff[NUM_INT] = num_int;
        //     send_event(cont, count, IGNRCONT);
        //     yield_terminate;
                
        // }
        if(op0 == 2){
            unsigned long num_int = lmbuff[NUM_INT];
            long num_total_lanes = lmbuff[NUM_LANES_TOTAL];
            
            long v2 = _max_vid;
            if(v1 > v2){
                num_int = num_int + 1;

                // next_nwid = hash(v1, hash(v2, HASH_SEED))
                unsigned int next_nwid = HASH_SEED;
                asm{
                    "hash %[src] %[dst]"
                }: [src] "r" (v2), [dst] "r" (next_nwid);
                asm{
                    "hash %[src] %[dst]"
                }: [src] "r" (v1), [dst] "r" (next_nwid);
                next_nwid = next_nwid & num_total_lanes;  // next_nwid = next_nwid % total_lanes
                unsigned long evword = evw_new(next_nwid, intersection_launcher__send_to_worker_thread4);

                temp_lmbuff[1] = v2;
                temp_lmbuff[2] = v2;
                send_event(evword, temp_lmbuff, 4, IGNRCONT);
            }
            lmbuff[NUM_INT] = num_int;
            send_event(cont, count, IGNRCONT);
            yield_terminate;
                
        }
        // Vertex needs to be counted
        long* nl_ptr = op2;
        nl_ptr_end = op2 + (op0 << 3);
        while(nl_ptr < nl_ptr_end){
            send_dram_read(nl_ptr, 8, v1_neighs);
            count = count + 1;
            nl_ptr = nl_ptr + 64;
        }
    }


    event v1_neighs(long op0, long op1, long op2,long op3,long op4,long op5,long op6, long op7, long* return_addr){
        // Update the return count
        unsigned long num_int = lmbuff[NUM_INT];
        long num_total_lanes = lmbuff[NUM_LANES_TOTAL];
        long* addr = return_addr;

        temp_lmbuff[0] = v1;
        temp_lmbuff[3] = NETID;
        
        if(addr < nl_ptr_end){
            long v2 = op0;
            if(v1 > v2){
                num_int = num_int + 1;

                // next_nwid = hash(v1, hash(v2, HASH_SEED))
                unsigned int next_nwid = HASH_SEED;
                asm{
                    "hash %[src] %[dst]"
                }: [src] "r" (v2), [dst] "r" (next_nwid);
                asm{
                    "hash %[src] %[dst]"
                }: [src] "r" (v1), [dst] "r" (next_nwid);
                next_nwid = next_nwid & num_total_lanes;  // next_nwid = next_nwid % total_lanes
                unsigned long evword = evw_new(next_nwid, intersection_launcher__send_to_worker_thread4);

                temp_lmbuff[1] = v2;
                temp_lmbuff[2] = v2;
                send_event(evword, temp_lmbuff, 4, IGNRCONT);

                // if(NETID == 47){
                //     print("send (%lu %lu) to lane %lu", v1, v2, next_nwid);
                // }
            }else{
                lmbuff[NUM_INT] = num_int;
                count = count - 1;
                if(count == 0){
                    send_event(cont, count, IGNRCONT);
                    yield_terminate;
                }
                yield;
            }
            addr = addr + 8;
        }else{
            lmbuff[NUM_INT] = num_int;
            count = count - 1;
            if(count == 0){
                send_event(cont, count, IGNRCONT);
                yield_terminate;
            }
            yield;
        }
        if(addr < nl_ptr_end){
            long v2 = op1;
            if(v1 > v2){
                num_int = num_int + 1;

                // next_nwid = hash(v1, hash(v2, HASH_SEED))
                unsigned int next_nwid = HASH_SEED;
                asm{
                    "hash %[src] %[dst]"
                }: [src] "r" (v2), [dst] "r" (next_nwid);
                asm{
                    "hash %[src] %[dst]"
                }: [src] "r" (v1), [dst] "r" (next_nwid);
                next_nwid = next_nwid & num_total_lanes;  // next_nwid = next_nwid % total_lanes
                unsigned long evword = evw_new(next_nwid, intersection_launcher__send_to_worker_thread4);

                temp_lmbuff[1] = v2;
                temp_lmbuff[2] = v2;
                send_event(evword, temp_lmbuff, 4, IGNRCONT);

                // if(NETID == 47){
                //     print("send (%lu %lu) to lane %lu", v1, v2, next_nwid);
                // }
            }else{
                lmbuff[NUM_INT] = num_int;
                count = count - 1;
                if(count == 0){
                    send_event(cont, count, IGNRCONT);
                    yield_terminate;
                }
                yield;
            }
            addr = addr + 8;
        }else{
            lmbuff[NUM_INT] = num_int;
            count = count - 1;
            if(count == 0){
                send_event(cont, count, IGNRCONT);
                yield_terminate;
            }
            yield;
        }
        if(addr < nl_ptr_end){
            long v2 = op2;
            if(v1 > v2){
                num_int = num_int + 1;

                // next_nwid = hash(v1, hash(v2, HASH_SEED))
                unsigned int next_nwid = HASH_SEED;
                asm{
                    "hash %[src] %[dst]"
                }: [src] "r" (v2), [dst] "r" (next_nwid);
                asm{
                    "hash %[src] %[dst]"
                }: [src] "r" (v1), [dst] "r" (next_nwid);
                next_nwid = next_nwid & num_total_lanes;  // next_nwid = next_nwid % total_lanes
                unsigned long evword = evw_new(next_nwid, intersection_launcher__send_to_worker_thread4);

                temp_lmbuff[1] = v2;
                temp_lmbuff[2] = v2;
                send_event(evword, temp_lmbuff, 4, IGNRCONT);

                // if(NETID == 47){
                //     print("send (%lu %lu) to lane %lu", v1, v2, next_nwid);
                // }
            }else{
                lmbuff[NUM_INT] = num_int;
                count = count - 1;
                if(count == 0){
                    send_event(cont, count, IGNRCONT);
                    yield_terminate;
                }
                yield;
            }
            addr = addr + 8;
        }else{
            lmbuff[NUM_INT] = num_int;
            count = count - 1;
            if(count == 0){
                send_event(cont, count, IGNRCONT);
                yield_terminate;
            }
            yield;
        }
        if(addr < nl_ptr_end){
            long v2 = op3;
            if(v1 > v2){
                num_int = num_int + 1;

                // next_nwid = hash(v1, hash(v2, HASH_SEED))
                unsigned int next_nwid = HASH_SEED;
                asm{
                    "hash %[src] %[dst]"
                }: [src] "r" (v2), [dst] "r" (next_nwid);
                asm{
                    "hash %[src] %[dst]"
                }: [src] "r" (v1), [dst] "r" (next_nwid);
                next_nwid = next_nwid & num_total_lanes;  // next_nwid = next_nwid % total_lanes
                unsigned long evword = evw_new(next_nwid, intersection_launcher__send_to_worker_thread4);

                temp_lmbuff[1] = v2;
                temp_lmbuff[2] = v2;
                send_event(evword, temp_lmbuff, 4, IGNRCONT);

                // if(NETID == 47){
                //     print("send (%lu %lu) to lane %lu", v1, v2, next_nwid);
                // }
            }else{
                lmbuff[NUM_INT] = num_int;
                count = count - 1;
                if(count == 0){
                    send_event(cont, count, IGNRCONT);
                    yield_terminate;
                }
                yield;
            }
            addr = addr + 8;
        }else{
            lmbuff[NUM_INT] = num_int;
            count = count - 1;
            if(count == 0){
                send_event(cont, count, IGNRCONT);
                yield_terminate;
            }
            yield;
        }
        if(addr < nl_ptr_end){
            long v2 = op4;
            if(v1 > v2){
                num_int = num_int + 1;

                // next_nwid = hash(v1, hash(v2, HASH_SEED))
                unsigned int next_nwid = HASH_SEED;
                asm{
                    "hash %[src] %[dst]"
                }: [src] "r" (v2), [dst] "r" (next_nwid);
                asm{
                    "hash %[src] %[dst]"
                }: [src] "r" (v1), [dst] "r" (next_nwid);
                next_nwid = next_nwid & num_total_lanes;  // next_nwid = next_nwid % total_lanes
                unsigned long evword = evw_new(next_nwid, intersection_launcher__send_to_worker_thread4);


// #define DEBUG
#define PRINT
#define NUM_THREADS 127
#define vertex_size (16 * 8)
#define NUM_DRAM_ACCESS 64
#define DATA_PER_THREAD (NUM_DRAM_ACCESS * 8)
// #define NUM_DRAM_ACCESS 32
// #define DATA_PER_THREAD 480

#define TOP_FLAG              0
#define THREAD_ID             1
#define NUM_MOVE              2
#define PARANT_NETID          3
#define NUM_CHILDREN          4
#define WORKLOAD              5
#define OUTGOING_WRITE        6
#define NUM_THREADS_PER_LANE  7
#define TOTAL_WEIGHT          8
#define SEND_BUFFER           16
#define HEAP                  32

#define args_scratch_space (LMBASE + SEND_BUFFER * 8)

#define HASH_SEED 0

#define EDGE_FACTOR 32
#define VERT_FACTOR 1

union uTest1 {
  long i;
  double f;
}


thread one_level_main_control {
  unsigned long num_verts;
  unsigned long num_edges;
  unsigned long* graph;
  unsigned long num_lanes;

  /* Initalize Scratchpad*/
  event init(unsigned long _num_verts, unsigned long _num_edges, unsigned long* _graph, unsigned long _num_lanes, unsigned long _total_weight){
    #ifdef PRINT
    print("Start Local Move");
    #endif

    unsigned long evwWord = evw_new(NETID, one_level_init_scratchpad::init);
    unsigned long *local args = args_scratch_space;
    args[0] = _num_lanes;
    args[1] = NETID;
    args[2] = 0;
    args[3] = _total_weight;
    send_event(evwWord, args, 4, start);

    num_verts = _num_verts;
    num_edges = _num_edges;
    graph = _graph;
    num_lanes = _num_lanes;

    yield;
  }

  /* Start LB framework */
  event start(){
    // print("start");
    unsigned long *local args = args_scratch_space;
    args[0] = num_verts;
    args[1] = num_edges;
    args[2] = graph;
    args[3] = (num_lanes * NUM_THREADS);
    args[4] = 0;
    args[5] = 0;
    args[6] = -1;
    unsigned long evwWord = evw_new(NETID, one_level_workload_split::start);
    send_event(evwWord, args, 7, IGNRCONT);
    yield_terminate;
  }

  event done(unsigned long _workload_done, unsigned long _nb_move){
    print("End Local Move");
    unsigned long *local scratch = LMBASE;
    scratch[NUM_MOVE] = _nb_move;
    scratch[TOP_FLAG] = 1;
    yield_terminate;
  }
}

thread one_level_init_scratchpad {
  unsigned long cont;
  unsigned long workload_done;
  unsigned long workload_total;

  /* Initialize Scratchpad */
  event init(unsigned long _num_lanes, unsigned long _netid, unsigned long _level, unsigned long _total_weight){
    if(_num_lanes == 1){
      send_event(CCONT, _num_lanes, IGNRCONT);
      if(_level == 0){
        cont = CCONT;
        workload_done = 0;
        workload_total = _num_lanes;
        unsigned long *local scratch = LMBASE;
        scratch[THREAD_ID] = 0;
        scratch[NUM_MOVE] = 0;
        scratch[PARANT_NETID] = _netid;
        scratch[NUM_CHILDREN] = _num_lanes;
        scratch[WORKLOAD] = _num_lanes;
        scratch[NUM_THREADS_PER_LANE] = NUM_THREADS;
        scratch[TOTAL_WEIGHT] = _total_weight;
        yield_terminate;
      }
      yield;
    }


    unsigned long half_num_lanes = _num_lanes >> 1;
    unsigned long *local args = args_scratch_space;
    args[0] =half_num_lanes;
    args[1] = NETID;
    args[2] = 1;
    args[3] = _total_weight;
    send_event(CEVNT, args, 4, done);
    // send_event(CEVNT, half_num_lanes, NETID, 1, done);
    unsigned long evwWord = evw_new((NETID + half_num_lanes), init);
    half_num_lanes = _num_lanes - half_num_lanes;
    args[0] =half_num_lanes;
    // args[1] = NETID;
    args[2] = 0;
    // args[3] = _total_weight;
    send_event(evwWord, args, 4, done);
    // send_event(evwWord, half_num_lanes, NETID, 0, done);

    if(_level == 0){
      cont = CCONT;
      workload_done = 0;
      workload_total = _num_lanes;
      unsigned long *local scratch = LMBASE;
      scratch[THREAD_ID] = 0;
      scratch[NUM_MOVE] = 0;
      scratch[PARANT_NETID] = _netid;
      scratch[NUM_CHILDREN] = _num_lanes;
      scratch[WORKLOAD] = _num_lanes;
      scratch[NUM_THREADS_PER_LANE] = NUM_THREADS;
      scratch[TOTAL_WEIGHT] = _total_weight;
    }

    yield;
  }

  event done(unsigned long _workload_done){
    workload_done = workload_done + _workload_done;
    if(workload_done == workload_total){
      send_event(cont, workload_done, IGNRCONT);
      yield_terminate;
    }
  }
}

thread one_level_workload_split {
  long num_verts;
  long num_edges;
  unsigned long* graph;
  long num_threads;
  unsigned long start_edges;
  unsigned long thread_id;

  unsigned long thread_id2;
  unsigned long *local scratch_val;

  event start(long _num_verts, long _num_edges, unsigned long* _graph, long _num_threads, unsigned long _start_edges, unsigned long _thread_id, long _tid){
    #ifdef DEBUG
    print("num_verts = %lu, num_edges = %lu, num_threads = %lu, thread_id = %lu, tid = %ld", _num_verts, _num_edges, _num_threads, _thread_id, _tid);
    #endif

    if(_num_threads <= 0){
      print("Error");
      yield_terminate;
    }

    // if no work left, update #threads on current lane, then updare next lane
    if(_num_verts == 0){
      // print("idle %lu threads, tid = %lu", _num_threads, _thread_id);
      unsigned long threads_in_lane = (NETID+1) * NUM_THREADS;
      threads_in_lane = threads_in_lane - _thread_id;
      /* If idle threads in one lane */
      if(_num_threads <= threads_in_lane){
        /* Update Scratchpad */
        unsigned long *local scratch = LMBASE;
        unsigned long total_threads  = scratch[NUM_THREADS_PER_LANE];
        total_threads  = total_threads  - _num_threads;
        scratch[NUM_THREADS_PER_LANE] = total_threads;

        if(scratch[THREAD_ID] == total_threads){
          unsigned long evwWord = evw_new(NETID, one_level_start_worker::start);
          unsigned long evwWord2 = evw_new(NETID, done);
          send_event(evwWord, total_threads, total_threads, evwWord2);
        }
        yield_terminate;
      }

      /* If idle threads cross lanes */
      unsigned long tmp = _num_threads - threads_in_lane;
      unsigned long *local args = args_scratch_space;
      args[0] = _num_verts;
      args[3] = tmp;
      tmp = NETID + 1;
      args[5] = tmp * NUM_THREADS;
      unsigned long evwWord = evw_new(tmp, start);
      send_event(evwWord, args, 7, IGNRCONT);

      /* Update Scratchpad */
      args = LMBASE;
      evwWord  = args[NUM_THREADS_PER_LANE];
      evwWord  = evwWord  - threads_in_lane;
      args[NUM_THREADS_PER_LANE] = evwWord;


      if(args[THREAD_ID] == evwWord){
        tmp = evw_new(NETID, one_level_start_worker::start);
        unsigned long evwWord2 = evw_new(NETID, done);
        send_event(tmp, evwWord, evwWord, evwWord2);
      }
      yield_terminate;
    }

    if(_num_threads == 1 || (_num_verts == 1 && _num_edges <= 8)){
      // get thread ID for private scratchpad
      unsigned long *local args = LMBASE;
      unsigned long tid;
      if(_tid == -1){
        tid = args[THREAD_ID];
        args[THREAD_ID] = tid + 1;
      }else{
        tid = _tid;
        args[NUM_THREADS_PER_LANE] = args[NUM_THREADS_PER_LANE] - 1;
      }

      unsigned long *local scratch = LMBASE + HEAP * 8 + tid * DATA_PER_THREAD;
      scratch[0] = 0; // multi verts in one thread
      scratch[1] = _num_verts;
      scratch[2] = _num_edges;
      scratch[3] = _graph;
      scratch[4] = _start_edges;
      scratch[5] = _thread_id;
      long tmp = evw_new(NETID, done);
      scratch[6] = tmp;

      tmp = _num_threads - 1;
      if(tmp > 0){
        args = args_scratch_space;
        args[0] = 0;
        args[3] = tmp;
        tmp = _thread_id + 1;
        args[5] = tmp;
        // args[6] = -1;
        tmp = tmp / NUM_THREADS;
        unsigned long evwWord = evw_new(tmp, start);
        send_event(evwWord, args, 7, IGNRCONT);
        if(tmp != NETID){
          args = LMBASE;
          tmp = args[NUM_THREADS_PER_LANE];
          tid = args[THREAD_ID];
          if(tid == tmp){
            tmp = evw_new(NETID, one_level_start_worker::start);
            unsigned long evwWord2 = evw_new(NETID, done);
            send_event(tmp, tid, tid, evwWord2);
          }
        }
      }else{
        args = LMBASE;
        tmp = args[NUM_THREADS_PER_LANE];
        tid = args[THREAD_ID];
        if(tid == tmp){
          tmp = evw_new(NETID, one_level_start_worker::start);
          unsigned long evwWord2 = evw_new(NETID, done);
          send_event(tmp, tid, tid, evwWord2);
        }
      }
      
      yield_terminate;
    }

    if(_num_verts == 1){ // only one vertex left, split the vertex
      unsigned long evwWord = evw_new(NETID, one_level_one_vertex_workload_split::start);
      unsigned long tmp = evw_new(NETID, done);
      send_ops(evwWord, _num_verts, 7, tmp);

      unsigned long *local scratch = LMBASE;
      tmp = scratch[WORKLOAD];
      tmp = tmp + 1;
      scratch[WORKLOAD] = tmp;
      // if(NETID == 80){
      //   print("workload + 1 = %lu", tmp);
      // }
      yield_terminate;
    }

    if(_num_verts >= 8 && _num_threads >= 8){
      unsigned long vid;
      if(_tid == -1){
        scratch_val = LMBASE;
        vid = scratch_val[THREAD_ID];
        scratch_val[THREAD_ID] = vid + 1;
        scratch_val[NUM_THREADS_PER_LANE] = scratch_val[NUM_THREADS_PER_LANE] + 1;
      }else{
        vid = _tid;
      }
      scratch_val = LMBASE + HEAP * 8 + vid * DATA_PER_THREAD;
      thread_id2 = vid;
      vid = 0;
      scratch_val[0] = vid;
      scratch_val[1] = _start_edges;

      scratch_val[16] = _num_verts;
      scratch_val[17] = _start_edges + _num_edges;

      unsigned long shift = _num_verts >> 3;
      unsigned long tmp = _num_verts - (shift << 3);
      long* v_addr = _graph;

      if(tmp == 0){
        vid = vid + shift;
        v_addr = _graph + (vid * vertex_size);
        send_dram_read(v_addr, 8, v_return0);
        scratch_val[2] = vid;
        vid = vid + shift;
        v_addr = _graph + (vid * vertex_size);
        send_dram_read(v_addr, 8, v_return1);
        scratch_val[4] = vid;
        vid = vid + shift;
        v_addr = _graph + (vid * vertex_size);
        send_dram_read(v_addr, 8, v_return2);
        scratch_val[6] = vid;
        vid = vid + shift;
        v_addr = _graph + (vid * vertex_size);
        send_dram_read(v_addr, 8, v_return3);
        scratch_val[8] = vid;
        vid = vid + shift;
        v_addr = _graph + (vid * vertex_size);
        send_dram_read(v_addr, 8, v_return4);
        scratch_val[10] = vid;
        vid = vid + shift;
        v_addr = _graph + (vid * vertex_size);
        send_dram_read(v_addr, 8, v_return5);
        scratch_val[12] = vid;
        vid = vid + shift;
        v_addr = _graph + (vid * vertex_size);
        send_dram_read(v_addr, 8, v_return6);
        scratch_val[14] = vid;
      }

      if(tmp == 1){
        vid = vid + shift + 1;
        v_addr = _graph + (vid * vertex_size);
        send_dram_read(v_addr, 8, v_return0);
        scratch_val[2] = vid;
        vid = vid + shift;
        v_addr = _graph + (vid * vertex_size);
        send_dram_read(v_addr, 8, v_return1);
        scratch_val[4] = vid;

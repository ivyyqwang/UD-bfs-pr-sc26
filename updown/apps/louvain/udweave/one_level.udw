        vid = vid + shift;
        v_addr = _graph + (vid * vertex_size);
        send_dram_read(v_addr, 8, v_return6);
        scratch_val[14] = vid;
      }

      if(tmp == 2){
        vid = vid + shift + 1;
        v_addr = _graph + (vid * vertex_size);
        send_dram_read(v_addr, 8, v_return0);
        scratch_val[2] = vid;
        vid = vid + shift + 1;
        v_addr = _graph + (vid * vertex_size);
        send_dram_read(v_addr, 8, v_return1);
        scratch_val[4] = vid;
        vid = vid + shift;
        v_addr = _graph + (vid * vertex_size);
        send_dram_read(v_addr, 8, v_return2);
        scratch_val[6] = vid;
        vid = vid + shift;
        v_addr = _graph + (vid * vertex_size);
        send_dram_read(v_addr, 8, v_return3);
        scratch_val[8] = vid;
        vid = vid + shift;
        v_addr = _graph + (vid * vertex_size);
        send_dram_read(v_addr, 8, v_return4);
        scratch_val[10] = vid;
        vid = vid + shift;
        v_addr = _graph + (vid * vertex_size);
        send_dram_read(v_addr, 8, v_return5);
        scratch_val[12] = vid;
        vid = vid + shift;
        v_addr = _graph + (vid * vertex_size);
        send_dram_read(v_addr, 8, v_return6);
        scratch_val[14] = vid;
      }

      if(tmp == 3){
        vid = vid + shift + 1;
        v_addr = _graph + (vid * vertex_size);
        send_dram_read(v_addr, 8, v_return0);
        scratch_val[2] = vid;
        vid = vid + shift + 1;
        v_addr = _graph + (vid * vertex_size);
        send_dram_read(v_addr, 8, v_return1);
        scratch_val[4] = vid;
        vid = vid + shift + 1;
        v_addr = _graph + (vid * vertex_size);
        send_dram_read(v_addr, 8, v_return2);
        scratch_val[6] = vid;
        vid = vid + shift;
        v_addr = _graph + (vid * vertex_size);
        send_dram_read(v_addr, 8, v_return3);
        scratch_val[8] = vid;
        vid = vid + shift;
        v_addr = _graph + (vid * vertex_size);
        send_dram_read(v_addr, 8, v_return4);
        scratch_val[10] = vid;
        vid = vid + shift;
        v_addr = _graph + (vid * vertex_size);
        send_dram_read(v_addr, 8, v_return5);
        scratch_val[12] = vid;
        vid = vid + shift;
        v_addr = _graph + (vid * vertex_size);
        send_dram_read(v_addr, 8, v_return6);

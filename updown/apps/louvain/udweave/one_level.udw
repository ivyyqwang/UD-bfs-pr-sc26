    }
    
    unsigned long vid = (_num_verts + 1) >> 1;
    // unsigned long vid = (_num_verts + 1) * ((_num_threads + 1) >> 1) / _num_threads;
    long* v_addr = _graph + (vid * vertex_size);
    send_dram_read(v_addr, 8, v_return);

    num_verts = _num_verts;
    num_edges = _num_edges;

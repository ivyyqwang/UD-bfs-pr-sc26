// #define DEBUG
#define PRINT
#define NUM_THREADS 60
#define NUM_CACHE_THREADS 128
#define vertex_size (16 * 8)
#define NUM_DRAM_ACCESS 64
#define DATA_PER_THREAD (NUM_DRAM_ACCESS * 8)

#define HASH_SEED 0


#define TOP_FLAG            0
#define THREAD_ID           1
#define CACHE_TID           2
#define PARANT_NETID          3
#define NUM_CHILDREN          4
#define WORKLOAD              5
#define OUTGOING_WRITE        6
#define NUM_THREADS_PER_LANE  7
#define NUM_LANES             8
#define SEND_BUFFER         16
#define HEAP                32

#define CACHE_OFFSET        32768
#define CACHE_LEN           1024

#define args_scratch_space (LMBASE + SEND_BUFFER * 8)


thread re_compute_attr_phase2_main_control {
  unsigned long num_verts;
  unsigned long num_edges;
  unsigned long* graph;
  unsigned long num_lanes;

  /* Initalize Scratchpad*/
  event init(unsigned long _num_verts, unsigned long _num_edges, unsigned long* _graph, unsigned long _num_lanes){
    #ifdef PRINT
    print("Start re_compute_attr_phase2");
    #endif

    unsigned long evwWord = evw_new(NETID, re_compute_attr_phase2_cache::init);
    unsigned long *local args = args_scratch_space;
    args[0] = _graph;
    args[1] = _num_lanes;
    args[2] = _num_lanes;
    args[3] = NETID;
    args[4] = 0;
    send_event(evwWord, args, 5, start);
   
    num_verts = _num_verts;
    num_edges = _num_edges;
    graph = _graph;
    num_lanes = _num_lanes;
    yield;
  }

  /* Start LB framework */
  event start(){
    // print("start");
    unsigned long *local args = args_scratch_space;
    args[0] = num_verts;
    args[1] = num_edges;
    args[2] = graph;
    args[3] = (num_lanes * NUM_THREADS);
    args[4] = 0;
    args[5] = 0;
    args[6] = -1;
    unsigned long evwWord = evw_new(NETID, re_compute_attr_phase2_workload_split::start);
    send_event(evwWord, args, 7, IGNRCONT);
    yield_terminate;
  }

  event clear_cache() {
    unsigned long *local scratch = LMBASE;
    num_lanes = scratch[NUM_LANES];
    // print("clear cache %lu", num_lanes);
    unsigned long evwWord = evw_new(NETID, re_compute_attr_phase2_cache::clear);
    send_event(evwWord, num_lanes, done);
    yield;
  }

  event done(){
    print("End re_compute_attr_phase2");
    unsigned long *local scratch = LMBASE;
    scratch[TOP_FLAG] = 1;
    yield_terminate;
  }
}

thread re_compute_attr_phase2_cache {
  unsigned long* graph;
  unsigned long cont;
  unsigned long workload_done;
  unsigned long workload_total;
  unsigned long total_lane;

  event init(unsigned long* _graph, unsigned long _num_lanes, unsigned long _total_lanes, unsigned long _netid, unsigned long _level){
    if(_num_lanes == 1){
      send_event(CCONT, _num_lanes, IGNRCONT);
      if(_level == 0){
        cont = CCONT;
        workload_done = 0;
        workload_total = _num_lanes;
        total_lane = _total_lanes;
        graph = _graph;
        unsigned long *local scratch = LMBASE;
        scratch[THREAD_ID] = 0;
        scratch[CACHE_TID] = TID;
        scratch[PARANT_NETID] = _netid;
        scratch[NUM_CHILDREN] = _num_lanes;
        scratch[WORKLOAD] = _num_lanes;
        scratch[NUM_THREADS_PER_LANE] = NUM_THREADS;
        scratch[NUM_LANES] = _num_lanes;

        /* clear cache scratchpad */
        scratch = LMBASE + CACHE_OFFSET;
        long tmp = CACHE_LEN;
        for(unsigned long i = 0; i < tmp; i = i + 1){
          scratch[0] = 0;
          scratch[1] = 0;
          scratch[2] = 0;
          scratch[3] = 0;
          scratch = scratch + 32;
        }
        yield;
      }
      yield;
    }

    unsigned long half_num_lanes = _num_lanes >> 1;
    unsigned long *local args = args_scratch_space;
    args[0] = _graph;
    args[1] = half_num_lanes;
    args[2] = _total_lanes;
    args[3] = NETID;
    args[4] = 1;
    unsigned long evwWord = evw_update_thread(CEVNT, TID);
    send_event(evwWord, args, 5, done);
    evwWord = evw_new((NETID + half_num_lanes), init);
    half_num_lanes = _num_lanes - half_num_lanes;
    args[1] = half_num_lanes;
    args[4] = 0;
    send_event(evwWord, args, 5, done);
    
    if(_level == 0){
      cont = CCONT;
      workload_done = 0;
      workload_total = _num_lanes;
      total_lane = _total_lanes;
      graph = _graph;
      unsigned long *local scratch = LMBASE;
      scratch[THREAD_ID] = 0;
      scratch[CACHE_TID] = TID;
      scratch[PARANT_NETID] = _netid;
      scratch[NUM_CHILDREN] = _num_lanes;
      scratch[WORKLOAD] = _num_lanes;
      scratch[NUM_THREADS_PER_LANE] = NUM_THREADS;
      scratch[NUM_LANES] = _num_lanes;

      /* clear cache scratchpad */
      long tmp = CACHE_LEN;
      scratch = LMBASE + CACHE_OFFSET;
      for(unsigned long i = 0; i < tmp; i = i + 1){
        scratch[0] = 0;
        scratch[1] = 0;
        scratch[2] = 0;
        scratch[3] = 0;
        scratch = scratch + 32;
      }
    }
    yield;
  }

  event done(unsigned long _workload_done){
    workload_done = workload_done + _workload_done;
    if(workload_done == workload_total){
      send_event(cont, workload_done, IGNRCONT);
      workload_total = 0;
      workload_done = 0;
      yield;
    }
  }

  event clear(unsigned long _num_lanes){
    cont = CCONT;
    workload_done = 0;
    workload_total = _num_lanes;

    if(_num_lanes == 1){
      unsigned long *local scratch = LMBASE;
      unsigned long tid = scratch[CACHE_TID];
      unsigned long evword2 = evw_update_event(CEVNT, clear_cache);
      unsigned long evword = evw_update_thread(evword2, tid);
      send_event(evword, _num_lanes, clear_done);
      yield;
    }

    unsigned long evwWord = evw_new(NETID, clear);
    unsigned long half_num_lanes = _num_lanes >> 1;
    send_event(evwWord, half_num_lanes, clear_done);
    evwWord = evw_new((NETID + half_num_lanes), clear);
    half_num_lanes = _num_lanes - half_num_lanes;
    send_event(evwWord, half_num_lanes, clear_done);
    yield;
  }

  event clear_done(unsigned long _workload_done){
    workload_done = workload_done + _workload_done;
    if(workload_done == workload_total){
      send_event(cont, workload_done, IGNRCONT);
      yield_terminate;
    }
  }

  event clear_cache(unsigned long _workload){
    workload_done = 0;
    long* local cache_lmbuff = LMBASE + CACHE_OFFSET;
    cont = CCONT;
    long tmp = CACHE_LEN;
    for(unsigned long i = 0; i < tmp; i = i + 1){
      if(cache_lmbuff[0] != 0){
        workload_done = workload_done + 1;
        long* addr = cache_lmbuff[0];
        send_dram_write(addr, cache_lmbuff + 8, 2, cache_write_back);
        cache_lmbuff[0] = 0;
        cache_lmbuff[1] = 0;
        cache_lmbuff[2] = 0;
        cache_lmbuff[3] = 0;
      }
      cache_lmbuff = cache_lmbuff + 32;
    }
    if(workload_done == 0){
      send_event(cont, 1, IGNRCONT);
      yield_terminate;
    }
  }

  event cache_write_back(){
    workload_done = workload_done - 1;
    if(workload_done == 0){
      send_event(cont, 1, IGNRCONT);
      yield_terminate;
    }
  }

  event cache_add(unsigned long _cid, unsigned long _tot, unsigned long _in){
    unsigned long cache_idx = HASH_SEED;
    unsigned long lane_id = _cid;
    asm{
      "hash %[src] %[dst]"
    }: [src] "r" (lane_id), [dst] "r" (cache_idx);
    lane_id = cache_idx & (total_lane - 1);
    cache_idx = cache_idx / total_lane;
    cache_idx = cache_idx & (CACHE_LEN - 1);

    // print("cid = %lu, lane id = %lu, cache id = %lu, total_lane = %lu", _cid, lane_id, cache_idx, total_lane);

    unsigned long evword = evw_new(lane_id, cache_receive);
    unsigned long *local args = args_scratch_space;
    args[0] = _cid;
    args[1] = _tot;
    args[2] = _in;
    args[3] = cache_idx;
    send_event(evword, args, 4, CCONT);

    yield;
  }

  event cache_receive(unsigned long _cid, unsigned long _tot, unsigned long _in, unsigned long _cache_idx){
    unsigned long *local scratch = LMBASE;
    unsigned long tid = scratch[CACHE_TID];
    unsigned long evword2 = evw_update_event(CEVNT, atomic_add);
    unsigned long evword = evw_update_thread(evword2, tid);
    send_ops(evword, _cid, 4, CCONT);
    yield_terminate;
  }

  event atomic_add(unsigned long _cid, double _tot, double _in, unsigned long _cache_idx){

    long* local cache_lmbuff = LMBASE + CACHE_OFFSET;
    unsigned long cache_value = _cache_idx * 32;
    cache_lmbuff = cache_lmbuff + cache_value;
    cache_value = cache_lmbuff[0];
    long* v_addr = graph + (_cid * vertex_size) + 40;
    double* local cache_lmbuff_double = cache_lmbuff;

    // cache hit
    if(cache_value == v_addr){
      if(_tot != 0){
        cache_lmbuff_double[1] = cache_lmbuff_double[1] + _tot;
      }
      if(_in != 0){
        cache_lmbuff_double[2] = cache_lmbuff_double[2] + _in;
      }
      send_event(CCONT, 0, IGNRCONT);
      yield;
    }

    if(cache_value == 0){  // empty cache
      cache_lmbuff[0] = v_addr;
      cache_lmbuff_double[1] = _tot;
      cache_lmbuff_double[2] = _in;
      cache_lmbuff[3] = CCONT; // flag current cache entry cannot be evicted
      send_dram_read(v_addr, 2, read_data);
      yield; 
    }

    // dirty cache
    if(cache_lmbuff[3] != 0){
      send_ops(CEVNT, _cid, 4, CCONT);
      yield;
    }

    long *addr_tmp = cache_lmbuff[0];
    send_dram_write(addr_tmp, cache_lmbuff + 8, 2, write_back_cache);
    cache_lmbuff[0] = v_addr;
    cache_lmbuff_double[1] = _tot;
    cache_lmbuff_double[2] = _in;
    cache_lmbuff[3] = CCONT; // flag current cache entry cannot be evicted
    yield; 
  }

  event write_back_cache(unsigned long * _addr){
    unsigned long cache_idx = HASH_SEED;
    unsigned long tmp =  (_addr - graph - 40);
    tmp = tmp / vertex_size;
    asm{
      "hash %[src] %[dst]"
    }: [src] "r" (tmp), [dst] "r" (cache_idx);
    cache_idx = cache_idx / total_lane;
    cache_idx = cache_idx & (CACHE_LEN - 1);

    long* local cache_lmbuff = LMBASE + CACHE_OFFSET;
    tmp = cache_idx * 32;
    cache_lmbuff = cache_lmbuff + tmp;
    long *addr_tmp = cache_lmbuff[0];
    send_dram_read(addr_tmp, 2, read_data);
    yield; 
  }

  event read_data(double _tot, double _in, unsigned long * _addr){
    unsigned long cache_idx = HASH_SEED;
    unsigned long tmp =  (_addr - graph - 40);
    tmp = tmp / vertex_size;
    asm{
      "hash %[src] %[dst]"
    }: [src] "r" (tmp), [dst] "r" (cache_idx);
    cache_idx = cache_idx / total_lane;
    cache_idx = cache_idx & (CACHE_LEN - 1);

    double* local cache_lmbuff_double = LMBASE + CACHE_OFFSET;
    tmp = cache_idx * 32;
    cache_lmbuff_double = cache_lmbuff_double + tmp;
    cache_lmbuff_double[1] = _tot + cache_lmbuff_double[1];
    cache_lmbuff_double[2] = _in + cache_lmbuff_double[2];
    long* local cache_lmbuff = cache_lmbuff_double;
    tmp = cache_lmbuff[3];
    send_event(tmp, 0, IGNRCONT);
    cache_lmbuff[3] = 0;
    yield;
  }
}

thread re_compute_attr_phase2_cache_update {
  unsigned long cont;
  unsigned long cont2;
  unsigned long workload_total;
  long* local cache_lmbuff;
  double* local cache_lmbuff_double;

  event atomic_add(long* _addr, double _tot, double _in, long* local _cache_lmbuff, unsigned long _cont){
    cache_lmbuff = _cache_lmbuff;
    cache_lmbuff_double = _cache_lmbuff;
    unsigned long cache_value = cache_lmbuff[0];
    // cache hit
    if(cache_value == _addr){
      if(_tot != 0){
        cache_lmbuff_double[1] = cache_lmbuff_double[1] + _tot;
      }
      if(_in != 0){
        cache_lmbuff_double[2] = cache_lmbuff_double[2] + _in;
      }
      send_event(CCONT, _cont, IGNRCONT);
      yield_terminate;
    }

    if(cache_value == 0){  // empty cache
      cache_lmbuff[0] = _addr;
      cache_lmbuff_double[1] = _tot;
      cache_lmbuff_double[2] = _in;
      cache_lmbuff[3] = 1; // flag current cache entry cannot be evicted
      send_dram_read(_addr, 2, read_data);
      workload_total = 1;
      cont2 = _cont;
      cont = CCONT;
      yield; 
    }

    // dirty cache
    if(cache_lmbuff[3] != 0){
      send_ops(CEVNT, _addr, 5, CCONT);
      yield;
    }

    send_dram_read(_addr, 2, read_data);
    long *addr_tmp = cache_lmbuff[0];
    send_dram_write(addr_tmp, cache_lmbuff + 8, 2, write_back_cache);
    cache_lmbuff[0] = _addr;
    cache_lmbuff_double[1] = _tot;
    cache_lmbuff_double[2] = _in;
    cache_lmbuff[3] = 1; // flag current cache entry cannot be evicted
    workload_total = 2;
    cont2 = _cont;
    cont = CCONT;
    yield; 
  }

  event write_back_cache(unsigned long * _addr){
    workload_total = workload_total - 1;
    if(workload_total == 0){
      cache_lmbuff[3] = 0;
      send_event(cont, cont2, IGNRCONT);
      yield_terminate;
    }
  }

  event read_data(double _tot, double _in, unsigned long * _addr){
    cache_lmbuff_double[1] = _tot + cache_lmbuff_double[1];
    cache_lmbuff_double[2] = _in + cache_lmbuff_double[2];
    workload_total = workload_total - 1;

    if(cache_lmbuff[0] != _addr){
      print("Error, addr cache not match!");
    }

    if(workload_total == 0){
      cache_lmbuff[3] = 0;
      send_event(cont, cont2, IGNRCONT);
      yield_terminate;
    }
  }
}

thread re_compute_attr_phase2_workload_split {
  unsigned long num_verts;
  unsigned long num_edges;
  unsigned long* graph;
  long num_threads;
  unsigned long start_edges;
  unsigned long thread_id;

  unsigned long thread_id2;
  unsigned long *local scratch_val;

  event start(long _num_verts, long _num_edges, unsigned long* _graph, long _num_threads, long _start_edges, long _thread_id, long _tid){
    #ifdef DEBUG
    print("num_verts = %lu, num_edges = %lu, num_threads = %lu, thread_id = %lu, tid = %ld", _num_verts, _num_edges, _num_threads, _thread_id, _tid);
    #endif

    // if no work left, update #threads on current lane, then updare next lane
    if(_num_verts == 0){
      unsigned long threads_in_lane = (NETID + 1) * NUM_THREADS;
      threads_in_lane = threads_in_lane - _thread_id;
      /* If idle threads in one lane */
      if(_num_threads <= threads_in_lane){
        /* Update Scratchpad */
        unsigned long *local scratch = LMBASE;
        unsigned long total_threads  = scratch[NUM_THREADS_PER_LANE];
        total_threads  = total_threads  - _num_threads;
        scratch[NUM_THREADS_PER_LANE] = total_threads;

        // print("thread_id = %lu, total_threads = %lu", scratch[THREAD_ID], total_threads);

        if(scratch[THREAD_ID] == total_threads){
          unsigned long evwWord = evw_new(NETID, re_compute_attr_phase2_start_worker::start);
          unsigned long evwWord2 = evw_new(NETID, done);
          send_event(evwWord, total_threads, total_threads, evwWord2);
        }
        yield_terminate;
      }
      /* If idle threads cross lanes */
      unsigned long tmp = _num_threads - threads_in_lane;
      unsigned long *local args = args_scratch_space;
      args[0] = _num_verts;
      args[3] = tmp;
      tmp = NETID + 1;
      args[5] = tmp * NUM_THREADS;
      unsigned long evwWord = evw_new(tmp, start);
      send_event(evwWord, args, 7, IGNRCONT);
      /* Update Scratchpad */
      args = LMBASE;
      evwWord  = args[NUM_THREADS_PER_LANE];
      evwWord  = evwWord  - threads_in_lane;
      args[NUM_THREADS_PER_LANE] = evwWord;

      // print("thread_id = %lu, total_threads = %lu", args[THREAD_ID], evwWord);

      if(args[THREAD_ID] == evwWord){
        tmp = evw_new(NETID, re_compute_attr_phase2_start_worker::start);
        unsigned long evwWord2 = evw_new(NETID, done);
        send_event(tmp, evwWord, evwWord, evwWord2);
      }
      yield_terminate;
    }


    if(_num_threads == 1 || (_num_verts == 1 && _num_edges <= 8)){
      // get thread ID for private scratchpad
      unsigned long *local args = LMBASE;
      unsigned long tid;
      if(_tid == -1){
        tid = args[THREAD_ID];
        args[THREAD_ID] = tid + 1;
      }else{
        tid = _tid;
        args[NUM_THREADS_PER_LANE] = args[NUM_THREADS_PER_LANE] - 1;
        // print("total_threads = %lu (-1)", args[NUM_THREADS_PER_LANE]);
      }

      unsigned long *local scratch = LMBASE + HEAP * 8 + tid * DATA_PER_THREAD;
      scratch[0] = 0; // multi verts in one thread
      scratch[1] = _num_verts;
      scratch[2] = _num_edges;
      scratch[3] = _graph;
      scratch[4] = _start_edges;
      scratch[5] = tid;
      long tmp = evw_new(NETID, done);
      scratch[6] = tmp;

      /* reset other threads if num_threads > 1*/
      tmp = _num_threads - 1;
      if(tmp > 0){
        args = args_scratch_space;
        args[0] = 0;
        args[3] = tmp;
        tmp = _thread_id + 1;
        args[5] = tmp;
        // args[6] = -1;
        tmp = tmp / NUM_THREADS;
        unsigned long evwWord = evw_new(tmp, start);
        send_event(evwWord, args, 7, IGNRCONT);
        if(tmp != NETID){
          args = LMBASE;
          tmp = args[NUM_THREADS_PER_LANE];
          tid = args[THREAD_ID];
          // print("thread_id = %lu, total_threads = %lu", tid, tmp);
          if(tid == tmp){
            tmp = evw_new(NETID, re_compute_attr_phase2_start_worker::start);
            unsigned long evwWord2 = evw_new(NETID, done);
            send_event(tmp, tid, tid, evwWord2);
          }
        }
      }else{
        args = LMBASE;
        tmp = args[NUM_THREADS_PER_LANE];
        tid = args[THREAD_ID];
        // print("thread_id = %lu, total_threads = %lu", tid, tmp);
        if(tid == tmp){
          tmp = evw_new(NETID, re_compute_attr_phase2_start_worker::start);
          unsigned long evwWord2 = evw_new(NETID, done);
          send_event(tmp, tid, tid, evwWord2);
        }
      }
      yield_terminate;
    }

    if(_num_verts == 1){ // only one vertex left, split the vertex
      unsigned long evwWord = evw_new(NETID, re_compute_attr_phase2_one_vertex_workload_split::start);
      unsigned long tmp = evw_new(NETID, done);
      send_ops(evwWord, _num_verts, 7, tmp);

      unsigned long *local scratch = LMBASE;
      tmp = scratch[WORKLOAD];
      tmp = tmp + 1;
      scratch[WORKLOAD] = tmp;
      // if(NETID == 1){
      //   print("worklod = %lu (+1)", tmp);
      // }
      yield_terminate;
    }

    /* split into 8 children workers */
    if(_num_verts >= 8 && _num_threads >= 8){
      if(_tid == -1){
        scratch_val = LMBASE;
        thread_id2 = scratch_val[THREAD_ID];
        scratch_val[THREAD_ID] = thread_id2 + 1;
        scratch_val[NUM_THREADS_PER_LANE] = scratch_val[NUM_THREADS_PER_LANE] + 1;
        // print("thread_id = %lu, total_threads = %lu (+1)", scratch_val[THREAD_ID], scratch_val[NUM_THREADS_PER_LANE]);
      }else{
        thread_id2 = _tid;
      }
      scratch_val = LMBASE + HEAP * 8 + thread_id2 * DATA_PER_THREAD;
      unsigned long vid = 0;
      scratch_val[0] = vid;
      scratch_val[1] = _start_edges;
      scratch_val[16] = _num_verts;
      scratch_val[17] = _start_edges + _num_edges;

      unsigned long shift = _num_verts >> 3;
      unsigned long tmp = _num_verts - (shift << 3);
      long* v_addr;

       if(tmp == 0){
        vid = vid + shift;
        v_addr = _graph + (vid * vertex_size);
        send_dram_read(v_addr, 8, v_return0);
        scratch_val[2] = vid;
        vid = vid + shift;
        v_addr = _graph + (vid * vertex_size);
        send_dram_read(v_addr, 8, v_return1);
        scratch_val[4] = vid;
        vid = vid + shift;
        v_addr = _graph + (vid * vertex_size);
        send_dram_read(v_addr, 8, v_return2);
        scratch_val[6] = vid;
        vid = vid + shift;
        v_addr = _graph + (vid * vertex_size);
        send_dram_read(v_addr, 8, v_return3);
        scratch_val[8] = vid;
        vid = vid + shift;
        v_addr = _graph + (vid * vertex_size);
        send_dram_read(v_addr, 8, v_return4);
        scratch_val[10] = vid;
        vid = vid + shift;
        v_addr = _graph + (vid * vertex_size);
        send_dram_read(v_addr, 8, v_return5);
        scratch_val[12] = vid;
        vid = vid + shift;
        v_addr = _graph + (vid * vertex_size);
        send_dram_read(v_addr, 8, v_return6);
        scratch_val[14] = vid;
      }

      if(tmp == 1){
        vid = vid + shift + 1;
        v_addr = _graph + (vid * vertex_size);
        send_dram_read(v_addr, 8, v_return0);
        scratch_val[2] = vid;
        vid = vid + shift;
        v_addr = _graph + (vid * vertex_size);
        send_dram_read(v_addr, 8, v_return1);
        scratch_val[4] = vid;
        vid = vid + shift;
        v_addr = _graph + (vid * vertex_size);
        send_dram_read(v_addr, 8, v_return2);
        scratch_val[6] = vid;
        vid = vid + shift;
        v_addr = _graph + (vid * vertex_size);
        send_dram_read(v_addr, 8, v_return3);
        scratch_val[8] = vid;
        vid = vid + shift;
        v_addr = _graph + (vid * vertex_size);
        send_dram_read(v_addr, 8, v_return4);
        scratch_val[10] = vid;
        vid = vid + shift;
        v_addr = _graph + (vid * vertex_size);
        send_dram_read(v_addr, 8, v_return5);
        scratch_val[12] = vid;
        vid = vid + shift;
        v_addr = _graph + (vid * vertex_size);
        send_dram_read(v_addr, 8, v_return6);
        scratch_val[14] = vid;
      }

      if(tmp == 2){
        vid = vid + shift + 1;
        v_addr = _graph + (vid * vertex_size);
        send_dram_read(v_addr, 8, v_return0);
        scratch_val[2] = vid;
        vid = vid + shift + 1;
        v_addr = _graph + (vid * vertex_size);
        send_dram_read(v_addr, 8, v_return1);
        scratch_val[4] = vid;
        vid = vid + shift;
        v_addr = _graph + (vid * vertex_size);
        send_dram_read(v_addr, 8, v_return2);
        scratch_val[6] = vid;
        vid = vid + shift;
        v_addr = _graph + (vid * vertex_size);
        send_dram_read(v_addr, 8, v_return3);
        scratch_val[8] = vid;
        vid = vid + shift;
        v_addr = _graph + (vid * vertex_size);
        send_dram_read(v_addr, 8, v_return4);
        scratch_val[10] = vid;
        vid = vid + shift;
        v_addr = _graph + (vid * vertex_size);
        send_dram_read(v_addr, 8, v_return5);

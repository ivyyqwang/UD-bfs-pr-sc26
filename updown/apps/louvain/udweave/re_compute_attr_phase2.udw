        scratch_val[12] = vid;
        vid = vid + shift + 1;
        v_addr = _graph + (vid * vertex_size);
        send_dram_read(v_addr, 8, v_return6);
        scratch_val[14] = vid;
      }
      
      num_verts = _num_verts;
      num_edges = _num_edges;
      graph = _graph;
      num_threads = _num_threads;
      start_edges = 7;
      thread_id = _thread_id;
      yield;
    }

    /* generate 2 childern workers */
    unsigned long vid = (_num_verts + 1) >> 1;
    long* v_addr = _graph + (vid * vertex_size);
    send_dram_read(v_addr, 8, v_return);
    num_verts = _num_verts;
    num_edges = _num_edges;
    graph = _graph;
    num_threads = _num_threads;
    start_edges = _start_edges;
    thread_id = _thread_id;
    thread_id2 = _tid;
    yield;
  }

  event v_return(unsigned long *_neigh_ptr, unsigned long _deg, unsigned long _edges_before, unsigned long _vid, unsigned long _comm, double _tot, double _in, double* _weight_ptr, long * _addr){
    unsigned long vid = (num_verts + 1) >> 1;
    unsigned long workload = num_edges + num_verts * 8;
    unsigned long first_workload = _edges_before - start_edges + vid * 8;
    unsigned long first_num_threads = first_workload * num_threads / workload;

    if(first_num_threads == 0){
      first_num_threads = 1;
    }
    if(first_num_threads >= num_threads){
      first_num_threads = num_threads - 1;
    }
    first_workload = _edges_before - start_edges;

    unsigned long *local args = args_scratch_space;
    args[0] = vid;
    args[1] = first_workload;
    args[2] = graph;
    args[3] = first_num_threads;
    args[4] = start_edges;
    args[5] = thread_id;
    args[6] = thread_id2;
    vid = evw_new(NETID, start);
    send_event(vid, args, 7, IGNRCONT);

    vid = (num_verts + 1) >> 1;
    args[0] = (num_verts - vid);
    args[1] = (num_edges - first_workload);
    args[2] = _addr;
    args[3] = (num_threads - first_num_threads);
    args[4] = _edges_before;
    workload = thread_id + first_num_threads;
    args[5] = workload;
    workload = workload / NUM_THREADS;
    args[6] = -1;
    vid = evw_new(workload, start);
    send_event(vid, args, 7, IGNRCONT);
    yield_terminate;
  }

#define v_return(num)                                                        \
  event v_return##num(unsigned long *_neigh_ptr, unsigned long _deg, unsigned long _edges_before, unsigned long _vid, unsigned long _comm, double _tot, double _in, double* _weight_ptr, long * _addr){       \
    start_edges = start_edges - 1;\
    scratch_val[(num*2+3)] = _edges_before;\
    if(start_edges > 0){\
      yield;\
    }\
\
    /* 1st partition */\
    unsigned long *local args = args_scratch_space;\
    unsigned long current_edges = scratch_val[3] - scratch_val[1];\
    unsigned long curent_verts = scratch_val[2] - scratch_val[0];\
    unsigned long tmp = num_edges + num_verts * 8;\
    long first_num_threads = current_edges + (curent_verts * 8);\
    first_num_threads = first_num_threads * num_threads / tmp;\
    if(first_num_threads == 0){\
      first_num_threads = 1;\
    }\
    if((num_threads - first_num_threads) < 7){\
      first_num_threads = num_threads - 7;\
    }\
    tmp = scratch_val[1];\
    args[0] = curent_verts;\
    args[1] = current_edges;\
    args[2] = graph;\
    args[3] = first_num_threads;\
    args[4] = tmp;\
    args[5] = thread_id;\
    args[6] = thread_id2;\
    tmp = thread_id / NUM_THREADS;\
    start_edges = evw_new(tmp, start);\
    send_event(start_edges, args, 7, IGNRCONT);\
    thread_id = thread_id + first_num_threads;\
    num_verts = num_verts - curent_verts;\
    num_edges = num_edges - current_edges;\
    num_threads = num_threads - first_num_threads;\
    graph = graph + (curent_verts * vertex_size);\
\
    /* 2nd partition */\
    current_edges = scratch_val[5] - scratch_val[3];\
    curent_verts = scratch_val[4] - scratch_val[2];\
    tmp = num_edges + num_verts * 8;\
    first_num_threads = current_edges + (curent_verts * 8);\
    first_num_threads = first_num_threads * num_threads / tmp;\
    if(first_num_threads == 0){\
      first_num_threads = 1;\
    }\
    if((num_threads - first_num_threads) < 6){\
      first_num_threads = num_threads - 6;\
    }\
    tmp = scratch_val[3];\
    \
    args[0] = curent_verts;\
    args[1] = current_edges;\
    args[2] = graph;\
    args[3] = first_num_threads;\
    args[4] = tmp;\
    args[5] = thread_id;\
    args[6] = -1;\
    tmp = thread_id / NUM_THREADS;\
    start_edges = evw_new(tmp, start);\
    send_event(start_edges, args, 7, IGNRCONT);\
    thread_id = thread_id + first_num_threads;\
    num_verts = num_verts - curent_verts;\
    num_edges = num_edges - current_edges;\
    num_threads = num_threads - first_num_threads;\
    graph = graph + (curent_verts * vertex_size);\
\
    /* 3nd partition */\
    current_edges = scratch_val[7] - scratch_val[5];\
    curent_verts = scratch_val[6] - scratch_val[4];\
    tmp = num_edges + num_verts * 8;\
    first_num_threads = current_edges + (curent_verts * 8);\
    first_num_threads = first_num_threads * num_threads / tmp;\
    if(first_num_threads == 0){\
      first_num_threads = 1;\
    }\
    if((num_threads - first_num_threads) < 5){\
      first_num_threads = num_threads - 5;\
    }\
    tmp = scratch_val[5];\
  \
    args[0] = curent_verts;\
    args[1] = current_edges;\
    args[2] = graph;\
    args[3] = first_num_threads;\
    args[4] = tmp;\
    args[5] = thread_id;\
    args[6] = -1;\
    tmp = thread_id / NUM_THREADS;\
    start_edges = evw_new(tmp, start);\
    send_event(start_edges, args, 7, IGNRCONT);\
    thread_id = thread_id + first_num_threads;\
    num_verts = num_verts - curent_verts;\
    num_edges = num_edges - current_edges;\
    num_threads = num_threads - first_num_threads;\
    graph = graph + (curent_verts * vertex_size);\
\
    /* 4st partition */\
    current_edges = scratch_val[9] - scratch_val[7];\
    curent_verts = scratch_val[8] - scratch_val[6];\
    tmp = num_edges + num_verts * 8;\
    first_num_threads = current_edges + (curent_verts * 8);\
    first_num_threads = first_num_threads * num_threads / tmp;\
    if(first_num_threads == 0){\
      first_num_threads = 1;\
    }\
    if((num_threads - first_num_threads) < 4){\
      first_num_threads = num_threads - 4;\
    }\
    tmp = scratch_val[7];\
    args[0] = curent_verts;\
    args[1] = current_edges;\
    args[2] = graph;\
    args[3] = first_num_threads;\
    args[4] = tmp;\
    args[5] = thread_id;\
    args[6] = -1;\
    tmp = thread_id / NUM_THREADS;\
    start_edges = evw_new(tmp, start);\
    send_event(start_edges, args, 7, IGNRCONT);\
    thread_id = thread_id + first_num_threads;\
    num_verts = num_verts - curent_verts;\
    num_edges = num_edges - current_edges;\
    num_threads = num_threads - first_num_threads;\
    graph = graph + (curent_verts * vertex_size);\
\
    /* 5st partition */\
    current_edges = scratch_val[11] - scratch_val[9];\
    curent_verts = scratch_val[10] - scratch_val[8];\
    tmp = num_edges + num_verts * 8;\
    first_num_threads = current_edges + (curent_verts * 8);\
    first_num_threads = first_num_threads * num_threads / tmp;\
    if(first_num_threads == 0){\
      first_num_threads = 1;\
    }\
    if((num_threads - first_num_threads) < 3){\
      first_num_threads = num_threads - 3;\
    }\
    tmp = scratch_val[9];\
    args[0] = curent_verts;\
    args[1] = current_edges;\
    args[2] = graph;\
    args[3] = first_num_threads;\
    args[4] = tmp;\
    args[5] = thread_id;\
    args[6] = -1;\
    tmp = thread_id / NUM_THREADS;\
    start_edges = evw_new(tmp, start);\
    send_event(start_edges, args, 7, IGNRCONT);\
    thread_id = thread_id + first_num_threads;\
    num_verts = num_verts - curent_verts;\
    num_edges = num_edges - current_edges;\
    num_threads = num_threads - first_num_threads;\
    graph = graph + (curent_verts * vertex_size);\
\
    /* 6st partition */\
    current_edges = scratch_val[13] - scratch_val[11];\
    curent_verts = scratch_val[12] - scratch_val[10];\
    tmp = num_edges + num_verts * 8;\
    first_num_threads = current_edges + (curent_verts * 8);\
    first_num_threads = first_num_threads * num_threads / tmp;\
    if(first_num_threads == 0){\
      first_num_threads = 1;\
    }\
    if((num_threads - first_num_threads) < 2){\
      first_num_threads = num_threads - 2;\
    }\
    tmp = scratch_val[11];\
    args[0] = curent_verts;\
    args[1] = current_edges;\
    args[2] = graph;\
    args[3] = first_num_threads;\
    args[4] = tmp;\
    args[5] = thread_id;\
    args[6] = -1;\
    tmp = thread_id / NUM_THREADS;\
    start_edges = evw_new(tmp, start);\
    send_event(start_edges, args, 7, IGNRCONT);\
    thread_id = thread_id + first_num_threads;\
    num_verts = num_verts - curent_verts;\
    num_edges = num_edges - current_edges;\
    num_threads = num_threads - first_num_threads;\
    graph = graph + (curent_verts * vertex_size);\
\
    /* 7st partition */\
    current_edges = scratch_val[15] - scratch_val[13];\
    curent_verts = scratch_val[14] - scratch_val[12];\
    tmp = num_edges + num_verts * 8;\
    first_num_threads = current_edges + (curent_verts * 8);\
    first_num_threads = first_num_threads * num_threads / tmp;\
    if(first_num_threads == 0){\
      first_num_threads = 1;\
    }\
    if((num_threads - first_num_threads) < 1){\
      first_num_threads = num_threads - 1;\
    }\
    tmp = scratch_val[13];\
    args[0] = curent_verts;\
    args[1] = current_edges;\
    args[2] = graph;\
    args[3] = first_num_threads;\
    args[4] = tmp;\
    args[5] = thread_id;\
    args[6] = -1;\
    tmp = thread_id / NUM_THREADS;\
    start_edges = evw_new(tmp, start);\
    send_event(start_edges, args, 7, IGNRCONT);\
    thread_id = thread_id + first_num_threads;\
    num_verts = num_verts - curent_verts;\
    num_edges = num_edges - current_edges;\
    num_threads = num_threads - first_num_threads;\
    graph = graph + (curent_verts * vertex_size);\
\
    /* 8st partition */\
    current_edges = scratch_val[17] - scratch_val[15];\
    curent_verts = scratch_val[16] - scratch_val[14];\
    tmp = scratch_val[15];\
    args[0] = curent_verts;\
    args[1] = current_edges;\
    args[2] = graph;\
    args[3] = num_threads;\
    args[4] = tmp;\
    args[5] = thread_id;\
    args[6] = -1;\
    tmp = thread_id / NUM_THREADS;\
    start_edges = evw_new(tmp, start);\
    send_event(start_edges, args, 7, IGNRCONT);\
    yield_terminate;\
  }

  v_return(0)
  v_return(1)
  v_return(2)
  v_return(3)
  v_return(4)
  v_return(5)
  v_return(6)

  event done(unsigned long _num_threads_done, unsigned long _netid){
    unsigned long *local scratch = LMBASE;
    unsigned long tmp = scratch[WORKLOAD];
    tmp = tmp - _num_threads_done;
    scratch[WORKLOAD] = tmp;

    // if(NETID == 1){
    //   print("worklod = %lu, num_threads_done = %lu from %lu", tmp, _num_threads_done, _netid);
    // }

    if(tmp == 0){
      tmp = scratch[PARANT_NETID];
      unsigned long evwWord = evw_new(tmp, done);
      if(NETID == 0){
        evwWord = evw_new(tmp, re_compute_attr_phase2_main_control::clear_cache);
      }
      tmp = scratch[NUM_CHILDREN];
      send_event(evwWord, tmp, NETID, IGNRCONT);
      // print("done %d,", NETID);
    }
    yield_terminate;
  }

  event write_done(){
    unsigned long *local scratch = LMBASE;
    unsigned long tmp = scratch[WORKLOAD];
    tmp = tmp - 1;
    scratch[WORKLOAD] = tmp;

    //  if(NETID == 1){
    //   print("worklod = %lu, num_threads_done = 1", tmp);
    // }

    if(tmp == 0){
      tmp = scratch[PARANT_NETID];
      unsigned long evwWord = evw_new(tmp, done);
      if(NETID == 0){
        evwWord = evw_new(tmp, re_compute_attr_phase2_main_control::clear_cache);
      }
      tmp = scratch[NUM_CHILDREN];
      send_event(evwWord, tmp, NETID, IGNRCONT);
      // print("done %d,", NETID);
    }
    yield_terminate;
  }
}

thread re_compute_attr_phase2_one_vertex_workload_split{
  unsigned long workload_done;
  unsigned long workload_total;
  double in;
  double tot;
  unsigned long* graph;
  unsigned long cid;
  unsigned long num_edges;
  unsigned long num_threads;
  unsigned long thread_id;
  long thread_id2;

  event start(unsigned long _num_verts, unsigned long _num_edges, unsigned long* _graph, unsigned long _num_threads, unsigned long _start_edges, unsigned long _thread_id, long _tid){
    // #ifdef DEBUG
    // print("num_verts = %lu, num_edges = %lu, num_threads = %lu, thread_id = %lu, tid = %ld", _num_verts, _num_edges, _num_threads, _thread_id, _tid);
    // #endif
    
    if(_num_verts != 1){
      print("Error, num_verts != 1");
    }

    send_dram_read(_graph, 8, read_vertex);
    
    num_edges = _num_edges;
    num_threads = _num_threads;
    thread_id = _thread_id;
    workload_done = 0;
    workload_total = _num_threads;
    in = 0.0;
    tot = 0.0;
    graph = _graph;
    thread_id2 = _tid;

    yield;
  }
  event read_vertex(unsigned long *_neigh_ptr, unsigned long _deg, unsigned long _edges_before, unsigned long _vid, unsigned long _comm, double _tot, double _in, unsigned long *_weight_ptr, long * _addr){    
    graph = graph - _vid * vertex_size;
    unsigned long tmp = ((num_edges + 15) >> 4) << 3;
    unsigned long *local args = args_scratch_space;
    args[0] = 1;
    args[1] = tmp;
    args[2] = graph;
    tmp = (num_threads + 1) >> 1;
    args[3] = tmp;
    args[4] = thread_id;
    args[5] = _neigh_ptr;
    args[6] = _weight_ptr;
    args[7] = _comm;
    args[8] = thread_id2;
    unsigned long evwWord = evw_new(NETID, start2);
    send_event(evwWord, args, 9, done_merge);

    tmp =  ((num_edges + 15) >> 4) << 3;
    args[5] =  _neigh_ptr + (tmp << 3);
    args[6] =  _weight_ptr + (tmp << 3);
    args[1] = (num_edges - tmp);
    tmp = (num_threads + 1)>> 1;
    args[3] = (num_threads - tmp);
    tmp = thread_id + tmp;
    args[4] = tmp;
    args[8] = -1;
    tmp = tmp / NUM_THREADS;
    evwWord = evw_new(tmp, start2);
    send_event(evwWord, args, 9, done_merge);

    cid = _comm;
    yield;
  }

  event done_merge(unsigned long _workload_done, double _in, double _tot){
    workload_done = workload_done + _workload_done;
    in = in + _in;
    tot = tot + _tot;
    if(workload_done == workload_total){
      unsigned long *local scratch = LMBASE;
      unsigned long tid = scratch[CACHE_TID];
      unsigned long evword2 = evw_update_event(CEVNT, re_compute_attr_phase2_cache::cache_add);
      unsigned long evword = evw_update_thread(evword2, tid);
      send_event(evword, cid, tot, in, write_done);
    }
  }

  event write_done(){
    unsigned long *local scratch = LMBASE;
    unsigned long tmp = scratch[WORKLOAD];
    tmp = tmp - 1;
    scratch[WORKLOAD] = tmp;

    // if(NETID == 1){
    //   print("worklod = %lu, num_threads_done = 1", tmp);
    // }

    if(tmp == 0){
      tmp = scratch[PARANT_NETID];
      unsigned long evwWord = evw_new(tmp, re_compute_attr_phase2_workload_split::done);
      if(NETID == 0){
        evwWord = evw_new(tmp, re_compute_attr_phase2_main_control::clear_cache);
      }
      tmp = scratch[NUM_CHILDREN];
      send_event(evwWord, tmp, NETID, IGNRCONT);
      // print("done %d,", NETID);
    }
    yield_terminate;
  }

  event start2(long _num_verts, long _num_edges, unsigned long* _graph, long _num_threads, unsigned long _thread_id, unsigned long *_neigh_ptr, unsigned long *_weight_ptr, unsigned long _cid, long _tid){
    #ifdef DEBUG
    print("num_verts = %lu, num_edges = %lu, num_threads = %lu, thread_id = %lu, tid = %ld", _num_verts, _num_edges, _num_threads, _thread_id, _tid);
    #endif

    // if no work left, update #threads on current lane, then updare next lane
    if(_num_verts == 0){
      unsigned long threads_in_lane = (NETID+1) * NUM_THREADS;
      threads_in_lane = threads_in_lane - _thread_id;
      /* If idle threads in one lane */
      if(_num_threads <= threads_in_lane){
        /* Update Scratchpad */
        unsigned long *local scratch = LMBASE;
        unsigned long total_threads  = scratch[NUM_THREADS_PER_LANE];
        total_threads  = total_threads  - _num_threads;
        scratch[NUM_THREADS_PER_LANE] = total_threads;
        // print("thread_id = %lu, total_threads = %lu", scratch[THREAD_ID], total_threads);
        if(scratch[THREAD_ID] == total_threads){
          unsigned long evwWord = evw_new(NETID, re_compute_attr_phase2_start_worker::start);
          send_event(evwWord, total_threads, total_threads, CCONT);
        }
        yield_terminate;
      }

      /* If idle threads cross lanes */
      unsigned long tmp = _num_threads - threads_in_lane;
      unsigned long *local args = args_scratch_space;
      args[0] = _num_verts;
      args[3] = tmp;
      tmp = NETID + 1;
      args[4] = tmp * NUM_THREADS;
      unsigned long evwWord = evw_new(tmp, start2);
      send_event(evwWord, args, 9, CCONT);

       /* Update Scratchpad */
      args = LMBASE;
      evwWord  = args[NUM_THREADS_PER_LANE];
      evwWord  = evwWord  - threads_in_lane;
      args[NUM_THREADS_PER_LANE] = evwWord;
      // print("thread_id = %lu, total_threads = %lu", args[THREAD_ID], evwWord);

      if(args[THREAD_ID] == evwWord){
        tmp = evw_new(NETID, re_compute_attr_phase2_start_worker::start);
        send_event(tmp, evwWord, evwWord, CCONT);
      }

      yield_terminate;
    }
    
    if(_num_threads == 1 || _num_edges <= 8){
      // get thread ID for private scratchpad
      unsigned long *local args = LMBASE;
      long tid = _tid;
      if(tid == -1){
        tid = args[THREAD_ID];
        args[THREAD_ID] = tid + 1;
      }else{
        args[NUM_THREADS_PER_LANE] = args[NUM_THREADS_PER_LANE] - 1;
        // print("total_threads = %lu (-1)", args[NUM_THREADS_PER_LANE]);
      }

      unsigned long *local scratch = LMBASE + HEAP * 8 + tid * DATA_PER_THREAD;
      scratch[0] = 1; // split one vertex in one thread
      scratch[1] = _num_verts;
      scratch[2] = _num_edges;
      scratch[3] = _graph;
      scratch[4] = tid;
      scratch[5] = _neigh_ptr;
      scratch[6] = _weight_ptr;
      scratch[7] = _cid;
      scratch[8] = CCONT;

      unsigned long tmp = _num_threads - 1;
      if(tmp > 0){
        unsigned long evwWord = 0;
        send_event(CCONT, tmp, evwWord , evwWord , IGNRCONT);
        args = args_scratch_space;
        args[0] = 0;
        args[3] = tmp;
        tmp = _thread_id + 1;
        args[4] = tmp;
        // args[6] = -1;
        tmp = tmp / NUM_THREADS;
        evwWord = evw_new(tmp, start2);
        send_event(evwWord, args, 9, IGNRCONT);
        if(tmp != NETID){
          args = LMBASE;
          tmp = args[NUM_THREADS_PER_LANE];
          tid = args[THREAD_ID];
          // print("thread_id = %lu, total_threads = %lu", tid, tmp);
          if(tid == tmp){
            tmp = evw_new(NETID, re_compute_attr_phase2_start_worker::start);
            send_event(tmp, tid, tid, CCONT);
          }
        }
      }else{
        args = LMBASE;
        tmp = args[NUM_THREADS_PER_LANE];
        tid = args[THREAD_ID];
        // print("thread_id = %lu, total_threads = %lu", tid, tmp);
        if(tid == tmp){
          tmp = evw_new(NETID, re_compute_attr_phase2_start_worker::start);
          send_event(tmp, tid, tid, CCONT);
        }
      }
      
      yield_terminate;
    }

    unsigned long tmp = ((_num_edges + 15) >> 4) << 3;
    unsigned long *local args = args_scratch_space;
    args[0] = _num_verts;
    args[1] = tmp;
    args[2] = _graph;
    tmp = (_num_threads + 1) >> 1;
    args[3] = tmp;
    args[4] = _thread_id;
    args[5] = _neigh_ptr;
    args[6] = _weight_ptr;
    args[7] = _cid;
    args[8] = _tid;
    unsigned long evwWord = evw_new(NETID, start2);
    send_event(evwWord, args, 9, CCONT);

    tmp = ((_num_edges + 15) >> 4) << 3;
    args[5] =  _neigh_ptr + (tmp << 3);
    args[6] =  _weight_ptr + (tmp << 3);
    args[1] = (_num_edges - tmp);
    tmp = (_num_threads + 1) >> 1;
    args[3] = (_num_threads - tmp);
    tmp = _thread_id + tmp;
    args[4] = tmp;
    args[8] = -1;
    tmp = tmp / NUM_THREADS;
    evwWord = evw_new(tmp, start2);
    send_event(evwWord, args, 9, CCONT);
    yield_terminate;
  }
}

thread re_compute_attr_phase2_start_worker{
  event start(unsigned long _num_threads){
    unsigned long tid = 0;
    unsigned long new_workload = 0;
    while(tid < _num_threads){
      unsigned long *local scratch = LMBASE + HEAP * 8 + tid * DATA_PER_THREAD;
      if(scratch[0] == 0){ // multi verts in one thread
          // print("scratch = 0x%lx, tid = %lu", scratch, tid);
        // print("num_verts = %lu, num_edges = %lu, graph = 0x%lx, start_edges = %lu, thread_id = %lu", scratch[1], scratch[2], scratch[3], scratch[4], scratch[5]);
        unsigned long tmp = scratch[6];
        unsigned long evwWord = evw_new(NETID, re_compute_attr_phase2_worker::start);
        send_event(evwWord, scratch + 8, 5, tmp);

        // send_event(tmp, 1, 0, IGNRCONT);
        new_workload = new_workload + 1;
      }else{
        // print("tid = %lu, num_verts = %lu, num_edges = %lu, vid = %lu, thread_id = %lu", tid, scratch[1], scratch[2], scratch[7], scratch[4]);
        unsigned long tmp = scratch[8];
        unsigned long evwWord = evw_new(NETID, re_compute_attr_phase2_one_vertex_worker::start);
        send_event(evwWord, scratch + 8, 7, tmp);

        // send_event(tmp, 1, 0, 0, IGNRCONT);
      }
      tid = tid + 1;
    }
    unsigned long *local scratch = LMBASE;
    tid = scratch[WORKLOAD];
    tid = tid + new_workload;
    tid = tid - 1;
    scratch[WORKLOAD] = tid;
    // if(NETID == 1){
    //   print("worklod = %lu, new_workload = %lu", tid, new_workload);
    // }

    if(tid == 0){
      unsigned long tmp = scratch[PARANT_NETID];
      unsigned long evwWord = evw_new(tmp, re_compute_attr_phase2_workload_split::done);
      if(NETID == 0){
        evwWord = evw_new(tmp, re_compute_attr_phase2_main_control::clear_cache);
      }
      tmp = scratch[NUM_CHILDREN];
      send_event(evwWord, tmp, NETID, IGNRCONT);
    }
    // print("Partition tree generated");
    yield_terminate;
  }
}


#define GRAPH 8
#define TOT   9
#define IN    10
#define CID   11
#define DEG   12
#define NEIGH_PTR   13
#define WEIGHT_PTR   14
#define COUNT 15

thread re_compute_attr_phase2_worker{
  unsigned long num_verts;
  unsigned long num_verts_done;
  unsigned long cont;
  unsigned long * graph;
  unsigned long *local scratch0;
  unsigned long *local scratch1;
  unsigned long *local scratch2;
  unsigned long *local scratch3;

  event start(long _num_verts, unsigned long _num_edges, unsigned long* _graph, unsigned long _start_edges, unsigned long _thread_id){
    // #ifdef DEBUG
    // print("num_verts = %lu, num_edges = %lu, thread_id = %lu, worload = %lu", _num_verts, _num_edges,  _thread_id, _num_verts * 8 + _num_edges);
    // #endif

    // if(_num_verts <= 2 || ((_num_edges / _num_verts) >= 32)){
      send_dram_read(_graph, 8, read_v);
      num_verts = _num_verts;
      num_verts_done = _thread_id;
      graph = _graph;
      cont = CCONT;
      yield;
    // }

    num_verts = _num_verts;
    graph = _graph;
    send_dram_read(graph, 8, read_v0);
    if(_num_verts > 1){
      graph = graph + vertex_size;
      send_dram_read(graph, 8, read_v1);
    }
    if(_num_verts > 2){
      graph = graph + vertex_size;
      send_dram_read(graph, 8, read_v2);
    }
    if(_num_verts > 3){
      graph = graph + vertex_size;
      send_dram_read(graph, 8, read_v3);
    }

    scratch0 = LMBASE + HEAP * 8 + _thread_id * DATA_PER_THREAD;
    scratch1 = scratch0 + 128;
    scratch2 = scratch1 + 128;
    scratch3 = scratch2 + 128;

    long tmp = 0;
    scratch0[TOT] = tmp;
    scratch0[IN] = tmp;
    num_verts = num_verts - 1; 

    if(_num_verts > 1){
      scratch1[TOT] = tmp;
      scratch1[IN] = tmp;
      num_verts = num_verts - 1;
    }

    if(_num_verts > 2){
      scratch2[TOT] = tmp;
      scratch2[IN] = tmp;
      num_verts = num_verts - 1;
    }

    if(_num_verts > 3){
      scratch3[TOT] = tmp;
      scratch3[IN] = tmp;
      num_verts = num_verts - 1;
    }

    cont = CCONT;
    num_verts_done = _num_verts;
  }

  event read_v(unsigned long *_neigh_ptr, unsigned long _deg, unsigned long _edges_before, unsigned long _vid, unsigned long _comm, double _tot, double _in, double* _weight_ptr, long * _addr){
    if(_deg == 0){
      // if(NETID == 1){
      //   print("num_verts = %lu", num_verts);
      // }
      num_verts = num_verts - 1;
      if(num_verts == 0){
        send_event(cont, 1, NETID, IGNRCONT);
        yield_terminate;
      }
      graph = graph + vertex_size;
      send_dram_read(graph, 8, read_v);
      yield;
    }
    
    unsigned long evwWord = evw_new(NETID, re_compute_attr_phase2_one_vertex_worker2::start);
    // get thread ID for private scratchpad
    unsigned long *local args = args_scratch_space;
    args[0] = 1;
    args[1] = _deg;
    args[2] = _addr - _vid * vertex_size;
    args[3] = num_verts_done;
    args[4] = _neigh_ptr;
    args[5] = _weight_ptr;
    args[6] = _comm;
    send_event(evwWord, args, 7, one_vertex_done);
    // print("send to re_compute_attr_phase2_one_vertex_worker2__start");
    scratch0 = _comm;
  }

  event one_vertex_done(unsigned long _workload_done, double _in, double _tot){
    // if(NETID == 1){
    //   print("num_verts = %lu", num_verts);
    // }
    unsigned long *local scratch = LMBASE;
    unsigned long tid = scratch[CACHE_TID];
    unsigned long evword2 = evw_update_event(CEVNT, re_compute_attr_phase2_cache::cache_add);
    unsigned long evword = evw_update_thread(evword2, tid);
    send_event(evword, scratch0, _tot, _in, next_vertex);
  }

  event next_vertex(){
    // if(NETID == 1){
    //   print("num_verts = %lu", num_verts);
    // }
    num_verts = num_verts - 1;
    if(num_verts == 0){
      send_event(cont, 1, NETID, IGNRCONT);
      yield_terminate;
    }
    graph = graph + vertex_size;
    send_dram_read(graph, 8, read_v);
    yield;
  }

#define read_v_template(num)                                                        \
  event read_v##num(unsigned long *_neigh_ptr, unsigned long _deg, unsigned long _edges_before, unsigned long _vid, unsigned long _comm, double _tot, double _in, double* _weight_ptr, long * _addr){       \
    unsigned long *local scratch = scratch##num;\
    if(_deg == 0){\
      num_verts_done = num_verts_done - 1;\
      if(num_verts_done == 0){\
        send_event(cont, 1, NETID, IGNRCONT);\
        yield_terminate;\
      }\
  \
      if(num_verts > 0){\
        graph = graph + vertex_size;\
        send_dram_read(graph, 8, read_v##num);\
        num_verts = num_verts - 1;\
        long tmp = 0;\
        scratch[TOT] = tmp;\
        scratch[IN] = tmp;\
        yield;\
      }\
    }\
    send_dram_read(_neigh_ptr, 8, read_neighbor##num);\
    scratch[DEG] = _deg;\
    scratch[NEIGH_PTR] = _neigh_ptr + 64;\
    scratch[WEIGHT_PTR] = _weight_ptr;\
    scratch[CID] = _comm;\
    scratch[GRAPH] = _addr - _vid * vertex_size + 32;\
  }

read_v_template(0)
read_v_template(1)
read_v_template(2)
read_v_template(3)


#define read_neighbor_template(num) \
  event read_neighbor##num(unsigned long op0, unsigned long op1, unsigned long op2, unsigned long op3, unsigned long op4, unsigned long op5, unsigned long op6, unsigned long op7){ \
    unsigned long *local scratch = scratch##num;\
    unsigned long deg = scratch[DEG];\
    unsigned long count = 0;\
    long * graph1 = scratch[GRAPH];\
    if(deg > 0){\
      send_dram_read(graph1 + op0 * vertex_size, 1, read_comm##num##_0);\
      count = count + 1;\
    }\
    if(deg > 1){\
      send_dram_read(graph1 + op1 * vertex_size, 1, read_comm##num##_1);\
      count = count + 1;\
    }\
    if(deg > 2){\
      send_dram_read(graph1 + op2 * vertex_size, 1, read_comm##num##_2);\
      count = count + 1;\
    }\
    if(deg > 3){\
      send_dram_read(graph1 + op3 * vertex_size, 1, read_comm##num##_3);\
      count = count + 1;\
    }\
    if(deg > 4){\
      send_dram_read(graph1 + op4 * vertex_size, 1, read_comm##num##_4);\
      count = count + 1;\
    }\
    if(deg > 5){\
      send_dram_read(graph1 + op5 * vertex_size, 1, read_comm##num##_5);\
      count = count + 1;\
    }\
    if(deg > 6){\
      send_dram_read(graph1 + op6 * vertex_size, 1, read_comm##num##_6);\
      count = count + 1;\
    }\
    if(deg > 7){\
      send_dram_read(graph1 + op7 * vertex_size, 1, read_comm##num##_7);\
      count = count + 1;\
    }\
    scratch[COUNT] = count;\
  }

read_neighbor_template(0)
read_neighbor_template(1)
read_neighbor_template(2)
read_neighbor_template(3)

#define read_comm_template(num1, num2) \
  event read_comm##num1##_##num2(unsigned long op0){ \
    unsigned long *local scratch = scratch##num1;\
    scratch[num2] = op0;\
    unsigned long count = scratch[COUNT];\
    count = count - 1;\
    scratch[COUNT] = count;\
    if(count == 0){\
      long * weight_ptr_start = scratch[WEIGHT_PTR];\
      send_dram_read(weight_ptr_start, 8, read_weight##num1);\
      weight_ptr_start = weight_ptr_start + 64;\
      scratch[WEIGHT_PTR] = weight_ptr_start;\
    }\
  }

read_comm_template(0, 0)
read_comm_template(0, 1)
read_comm_template(0, 2)
read_comm_template(0, 3)
read_comm_template(0, 4)
read_comm_template(0, 5)
read_comm_template(0, 6)
read_comm_template(0, 7)
read_comm_template(1, 0)
read_comm_template(1, 1)
read_comm_template(1, 2)
read_comm_template(1, 3)
read_comm_template(1, 4)
read_comm_template(1, 5)
read_comm_template(1, 6)
read_comm_template(1, 7)
read_comm_template(2, 0)
read_comm_template(2, 1)
read_comm_template(2, 2)
read_comm_template(2, 3)
read_comm_template(2, 4)
read_comm_template(2, 5)
read_comm_template(2, 6)
read_comm_template(2, 7)
read_comm_template(3, 0)
read_comm_template(3, 1)
read_comm_template(3, 2)
read_comm_template(3, 3)
read_comm_template(3, 4)
read_comm_template(3, 5)
read_comm_template(3, 6)
read_comm_template(3, 7)

#define read_weight_template(num) \
  event read_weight##num(double op0, double op1, double op2, double op3, double op4, double op5, double op6, double op7){\
    unsigned long *local scratch = scratch##num;\
    double *local scratch_double = scratch##num;\
    unsigned long deg = scratch[DEG];\
    unsigned long * neigh_ptr = scratch[NEIGH_PTR];\
    if(deg > 8){\
      send_dram_read(neigh_ptr, 8, read_neighbor##num);\
      neigh_ptr = neigh_ptr + 64;\
      scratch[NEIGH_PTR] = neigh_ptr;\
    }\
    double tot = scratch_double[TOT];\
    double in = scratch_double[IN];\
    unsigned long vid = scratch[CID];\
    if(deg > 0){\
      tot = tot + op0;\
      if(vid == scratch[0]){\
        in = in + op0;\
      }\
      deg = deg - 1;\
    }\
    if(deg > 0){\
      tot = tot + op1;\
      if(vid == scratch[1]){\
        in = in + op1;\
      }\
      deg = deg - 1;\
    }\
    if(deg > 0){\
      tot = tot + op2;\
      if(vid == scratch[2]){\
        in = in + op2;\
      }\
      deg = deg - 1;\
    }\
    if(deg > 0){\
      tot = tot + op3;\
      if(vid == scratch[3]){\
        in = in + op3;\
      }\
      deg = deg - 1;\
    }\
    if(deg > 0){\
      tot = tot + op4;\
      if(vid == scratch[4]){\
        in = in + op4;\
      }\
      deg = deg - 1;\
    }\
    if(deg > 0){\
      tot = tot + op5;\
      if(vid == scratch[5]){\
        in = in + op5;\
      }\
      deg = deg - 1;\
    }\
    if(deg > 0){\
      tot = tot + op6;\
      if(vid == scratch[6]){\
        in = in + op6;\
      }\
      deg = deg - 1;\
    }\
    if(deg > 0){\
      tot = tot + op7;\
      if(vid == scratch[7]){\
        in = in + op7;\
      }\
      deg = deg - 1;\
    }\
    scratch[DEG] = deg;\
    scratch_double[TOT] = tot;\
    scratch_double[IN] = in;\
\
    if(deg == 0){\
      scratch = LMBASE;\
      unsigned long tid = scratch[CACHE_TID];\
      unsigned long evword2 = evw_update_event(CEVNT, re_compute_attr_phase2_cache::cache_add);\
      unsigned long evword = evw_update_thread(evword2, tid);\
      send_event(evword, vid, tot, in, next_vertex##num);\
      yield;\
    }\
  }

read_weight_template(0)
read_weight_template(1)
read_weight_template(2)
read_weight_template(3)

#define next_vertex_template(num) \
  event next_vertex##num(){\
    unsigned long *local scratch = scratch##num;\
    num_verts_done = num_verts_done - 1;\
    if(num_verts_done == 0){\
      send_event(cont, 1, NETID, IGNRCONT);\
      yield_terminate;\
    }\
\
    if(num_verts > 0){\
      graph = graph + vertex_size;\
      send_dram_read(graph, 8, read_v##num);\
      num_verts = num_verts - 1;\
      long tmp = 0;\
      scratch[TOT] = tmp;\
      scratch[IN] = tmp;\
      yield;\
    }\
  }

next_vertex_template(0)
next_vertex_template(1)
next_vertex_template(2)
next_vertex_template(3)
}

thread re_compute_attr_phase2_one_vertex_worker{
  unsigned long vid;
  unsigned long outgoing;
  double in;
  double tot;
  unsigned long * graph;
  unsigned long cont;
  unsigned long *local scratch;
  unsigned long deg;
  unsigned long * neigh_ptr;
  unsigned long * neigh_ptr_start;
  double * weight_ptr_start;
  unsigned long count;

  event start(unsigned long _num_verts, unsigned long _num_edges, unsigned long* _graph, unsigned long _thread_id, unsigned long *_neigh_ptr, double *_weight_ptr, unsigned long _cid){
    // #ifdef DEBUG
    // print("num_verts = %lu, num_edges = %lu, thread_id = %lu, cid = %lu, workload = %lu", _num_verts, _num_edges, _thread_id, _cid, _num_edges);
    // #endif
    // send_event(CCONT, 1, 0, 0, IGNRCONT);
    // yield_terminate;

    if(_num_verts != 1){
      print("Error, num_verts  = %lu not 1", _num_verts);
    }

    graph = _graph + 32;
    cont = CCONT;
    scratch = LMBASE + HEAP * 8 + _thread_id * DATA_PER_THREAD;
    deg = _num_edges;
    neigh_ptr = _neigh_ptr;
    weight_ptr_start = _weight_ptr;
    neigh_ptr_start = neigh_ptr;

    // if(deg <= 8){
      send_dram_read(neigh_ptr, 8, read_neighbor_low_deg);
      neigh_ptr = neigh_ptr + 64;
      vid = _cid;
      in = 0.0;
      tot = 0.0;
      yield;
    // }

    long idx = 0;
    outgoing = 0;
    while((idx < deg) && (idx < NUM_DRAM_ACCESS)){
      send_dram_read(neigh_ptr, 8, read_neighbor);
      neigh_ptr = neigh_ptr + 64;
      idx = idx + 8;
      outgoing = outgoing + 1;
    }
    
    vid = _cid;
    in = 0.0;
    tot = 0.0;
  }

  event read_neighbor_low_deg(unsigned long op0, unsigned long op1, unsigned long op2, unsigned long op3, unsigned long op4, unsigned long op5, unsigned long op6, unsigned long op7){
    count = 0;
    if(deg > 0){
      send_dram_read(graph + op0 * vertex_size, 1, read_comm_low_deg_0);
      count = count + 1;
    }
    if(deg > 1){
      send_dram_read(graph + op1 * vertex_size, 1, read_comm_low_deg_1);
      count = count + 1;
    }
    if(deg > 2){
      send_dram_read(graph + op2 * vertex_size, 1, read_comm_low_deg_2);
      count = count + 1;
    }
    if(deg > 3){
      send_dram_read(graph + op3 * vertex_size, 1, read_comm_low_deg_3);
      count = count + 1;
    }
    if(deg > 4){
      send_dram_read(graph + op4 * vertex_size, 1, read_comm_low_deg_4);
      count = count + 1;
    }
    if(deg > 5){
      send_dram_read(graph + op5 * vertex_size, 1, read_comm_low_deg_5);
      count = count + 1;
    }
    if(deg > 6){
      send_dram_read(graph + op6 * vertex_size, 1, read_comm_low_deg_6);
      count = count + 1;
    }
    if(deg > 7){
      send_dram_read(graph + op7 * vertex_size, 1, read_comm_low_deg_7);
      count = count + 1;
    }
  }

  #define read_comm_low_deg_template(num) \
  event read_comm_low_deg_##num(unsigned long op0){\
    scratch[num] = op0;\
    count = count - 1;\
    if(count == 0){\
      send_dram_read(weight_ptr_start, 8, read_weight_low_deg);\
      weight_ptr_start = weight_ptr_start + 64;\
    }\
  }

read_comm_low_deg_template(0)
read_comm_low_deg_template(1)
read_comm_low_deg_template(2)
read_comm_low_deg_template(3)
read_comm_low_deg_template(4)
read_comm_low_deg_template(5)
read_comm_low_deg_template(6)
read_comm_low_deg_template(7)

  event read_weight_low_deg(double op0, double op1, double op2, double op3, double op4, double op5, double op6, double op7){
    if(deg > 8){
      send_dram_read(neigh_ptr, 8, read_neighbor_low_deg);
      neigh_ptr = neigh_ptr + 64;
    }
    if(deg > 0){
      tot = tot + op0;
      if(vid == scratch[0]){
        in = in + op0;
      }
      deg = deg - 1;
      if(deg == 0){
        send_event(cont, 1, in, tot, IGNRCONT);
        yield_terminate;
      }
    }

    if(deg > 0){
      tot = tot + op1;
      if(vid == scratch[1]){
        in = in + op1;
      }
      deg = deg - 1;
      if(deg == 0){
        send_event(cont, 1, in, tot, IGNRCONT);
        yield_terminate;
      }
    }

    if(deg > 0){
      tot = tot + op2;
      if(vid == scratch[2]){
        in = in + op2;
      }
      deg = deg - 1;
      if(deg == 0){
        send_event(cont, 1, in, tot, IGNRCONT);
        yield_terminate;
      }
    }

    if(deg > 0){
      tot = tot + op3;
      if(vid == scratch[3]){
        in = in + op3;
      }
      deg = deg - 1;
      if(deg == 0){
        send_event(cont, 1, in, tot, IGNRCONT);
        yield_terminate;
      }
    }

    if(deg > 0){
      tot = tot + op4;
      if(vid == scratch[4]){
        in = in + op4;
      }
      deg = deg - 1;
      if(deg == 0){
        send_event(cont, 1, in, tot, IGNRCONT);
        yield_terminate;
      }
    }

    if(deg > 0){
      tot = tot + op5;
      if(vid == scratch[5]){
        in = in + op5;
      }
      deg = deg - 1;
      if(deg == 0){
        send_event(cont, 1, in, tot, IGNRCONT);
        yield_terminate;
      }
    }

    if(deg > 0){
      tot = tot + op6;
      if(vid == scratch[6]){
        in = in + op6;
      }
      deg = deg - 1;
      if(deg == 0){
        send_event(cont, 1, in, tot, IGNRCONT);
        yield_terminate;
      }
    }

    if(deg > 0){
      tot = tot + op7;
      if(vid == scratch[7]){
        in = in + op7;
      }
      deg = deg - 1;
      if(deg == 0){
        send_event(cont, 1, in, tot, IGNRCONT);
        yield_terminate;
      }
    }
  }

  event read_neighbor(unsigned long op0, unsigned long op1, unsigned long op2, unsigned long op3, unsigned long op4, unsigned long op5, unsigned long op6, unsigned long op7, unsigned long * _addr){
    unsigned long offset = _addr - neigh_ptr_start;
    unsigned long tmp = offset & (NUM_DRAM_ACCESS * 8 - 1);
    copyOperands(op0, scratch + tmp, 8);
    send_dram_read(weight_ptr_start + offset, 8, read_weight);
  }

  event read_weight(double op0, double op1, double op2, double op3, double op4, double op5, double op6, double op7, unsigned long * _addr){
    unsigned long offset = _addr - weight_ptr_start;
    unsigned long idx = offset >> 3;
    idx = idx + NUM_DRAM_ACCESS;
    if(idx < deg){ //read next 8 words
      idx = idx << 3;
      unsigned long *addr = neigh_ptr_start + idx;
      send_dram_read(addr, 8, read_neighbor);
      idx = idx & (NUM_DRAM_ACCESS * 8 - 1);
      unsigned long *local scratch_tmp = scratch + idx;

      tot = tot + op0;
      if(vid == scratch_tmp[0]){
        in = in + op0;
      }
      tot = tot + op1;
      if(vid == scratch_tmp[1]){
        in = in + op1;
      }
      tot = tot + op2;
      if(vid == scratch_tmp[2]){
        in = in + op2;
      }
      tot = tot + op3;
      if(vid == scratch_tmp[3]){
        in = in + op3;
      }
      tot = tot + op4;
      if(vid == scratch_tmp[4]){
        in = in + op4;
      }
      tot = tot + op5;
      if(vid == scratch_tmp[5]){
        in = in + op5;
      }
      tot = tot + op6;
      if(vid == scratch_tmp[6]){
        in = in + op6;
      }
      tot = tot + op7;
      if(vid == scratch_tmp[7]){
        in = in + op7;
      }
      yield;
    }

    outgoing = outgoing - 1;

    idx = idx - NUM_DRAM_ACCESS;
    offset = offset & (NUM_DRAM_ACCESS * 8 - 1);
    unsigned long *local scratch_tmp = scratch + offset;
    if(deg > idx){
      tot = tot + op0;
      if(vid == scratch_tmp[0]){
        in = in + op0;
      }
      idx = idx + 1;
    }
    if(deg > idx){
      tot = tot + op1;
      if(vid == scratch_tmp[1]){
        in = in + op1;
      }
      idx = idx + 1;
    }

    if(deg > idx){
      tot = tot + op2;
      if(vid == scratch_tmp[2]){
        in = in + op2;
      }
      idx = idx + 1;
    }

    if(deg > idx){
      tot = tot + op3;
      if(vid == scratch_tmp[3]){
        in = in + op3;
      }
      idx = idx + 1;
    }
    if(deg > idx){
      tot = tot + op4;
      if(vid == scratch_tmp[4]){
        in = in + op4;
      }
      idx = idx + 1;
    }
    if(deg > idx){
      tot = tot + op5;
      if(vid == scratch_tmp[5]){
        in = in + op5;
      }
      idx = idx + 1;
    }
    if(deg > idx){
      tot = tot + op6;
      if(vid == scratch_tmp[6]){
        in = in + op6;
      }
      idx = idx + 1;
    }
    if(deg > idx){
      tot = tot + op7;
      if(vid == scratch_tmp[7]){
        in = in + op7;
      }
      idx = idx + 1;
    }
 
    if(outgoing == 0){
      send_event(cont, 1, in, tot, IGNRCONT);
      yield_terminate;
    }
  }
}


thread re_compute_attr_phase2_one_vertex_worker2{
  unsigned long vid;
  unsigned long outgoing;
  double in;
  double tot;
  unsigned long * graph;
  unsigned long cont;
  unsigned long *local scratch;
  unsigned long deg;
  unsigned long * neigh_ptr;
  unsigned long * neigh_ptr_start;
  double * weight_ptr_start;
  unsigned long count;

  event start(unsigned long _num_verts, unsigned long _num_edges, unsigned long* _graph, unsigned long _thread_id, unsigned long *_neigh_ptr, double *_weight_ptr, unsigned long _cid){
    // #ifdef DEBUG
    // print("num_verts = %lu, num_edges = %lu, thread_id = %lu, cid = %lu, _graph = %lu", _num_verts, _num_edges, _thread_id, _cid, _graph);
    // #endif
    // send_event(CCONT, 1, 0, 0, IGNRCONT);
    // yield_terminate;

    if(_num_verts != 1){
      print("Error, num_verts  = %lu not 1", _num_verts);
    }

    graph = _graph + 32;
    cont = CCONT;
    scratch = LMBASE + HEAP * 8 + _thread_id * DATA_PER_THREAD;
    deg = _num_edges;
    neigh_ptr = _neigh_ptr;
    weight_ptr_start = _weight_ptr;
    neigh_ptr_start = neigh_ptr;

    // if(deg <= 8){
      send_dram_read(neigh_ptr, 8, read_neighbor_low_deg);
      neigh_ptr = neigh_ptr + 64;
      vid = _cid;
      in = 0.0;
      tot = 0.0;
      yield;
    // }

    long idx = 0;
    outgoing = 0;
    while((idx < deg) && (idx < NUM_DRAM_ACCESS)){
      send_dram_read(neigh_ptr, 8, read_neighbor);
      neigh_ptr = neigh_ptr + 64;
      idx = idx + 8;
      outgoing = outgoing + 1;
    }
    
    vid = _cid;
    in = 0.0;
    tot = 0.0;
  }

  event read_neighbor_low_deg(unsigned long op0, unsigned long op1, unsigned long op2, unsigned long op3, unsigned long op4, unsigned long op5, unsigned long op6, unsigned long op7){
    count = 0;
    if(deg > 0){
      send_dram_read(graph + op0 * vertex_size, 1, read_comm_low_deg_0);
      count = count + 1;
    }
    if(deg > 1){
      send_dram_read(graph + op1 * vertex_size, 1, read_comm_low_deg_1);
      count = count + 1;
    }
    if(deg > 2){
      send_dram_read(graph + op2 * vertex_size, 1, read_comm_low_deg_2);
      count = count + 1;
    }
    if(deg > 3){
      send_dram_read(graph + op3 * vertex_size, 1, read_comm_low_deg_3);
      count = count + 1;
    }
    if(deg > 4){
      send_dram_read(graph + op4 * vertex_size, 1, read_comm_low_deg_4);
      count = count + 1;
    }
    if(deg > 5){
      send_dram_read(graph + op5 * vertex_size, 1, read_comm_low_deg_5);
      count = count + 1;
    }
    if(deg > 6){
      send_dram_read(graph + op6 * vertex_size, 1, read_comm_low_deg_6);
      count = count + 1;
    }
    if(deg > 7){
      send_dram_read(graph + op7 * vertex_size, 1, read_comm_low_deg_7);
      count = count + 1;
    }
  }

  #define read_comm_low_deg_template(num) \
  event read_comm_low_deg_##num(unsigned long op0){\
    scratch[num] = op0;\
    count = count - 1;\
    if(count == 0){\
      send_dram_read(weight_ptr_start, 8, read_weight_low_deg);\
      weight_ptr_start = weight_ptr_start + 64;\
    }\
  }

read_comm_low_deg_template(0)
read_comm_low_deg_template(1)
read_comm_low_deg_template(2)
read_comm_low_deg_template(3)
read_comm_low_deg_template(4)
read_comm_low_deg_template(5)
read_comm_low_deg_template(6)
read_comm_low_deg_template(7)

  event read_weight_low_deg(double op0, double op1, double op2, double op3, double op4, double op5, double op6, double op7){
    if(deg > 8){
      send_dram_read(neigh_ptr, 8, read_neighbor_low_deg);
      neigh_ptr = neigh_ptr + 64;
    }
    if(deg > 0){
      tot = tot + op0;
      if(vid == scratch[0]){
        in = in + op0;
      }
      deg = deg - 1;
      if(deg == 0){
        send_event(cont, 1, in, tot, IGNRCONT);
        yield_terminate;
      }
    }

    if(deg > 0){
      tot = tot + op1;
      if(vid == scratch[1]){
        in = in + op1;
      }
      deg = deg - 1;
      if(deg == 0){
        send_event(cont, 1, in, tot, IGNRCONT);
        yield_terminate;
      }
    }

    if(deg > 0){
      tot = tot + op2;
      if(vid == scratch[2]){
        in = in + op2;
      }
      deg = deg - 1;
      if(deg == 0){
        send_event(cont, 1, in, tot, IGNRCONT);
        yield_terminate;
      }
    }

    if(deg > 0){
      tot = tot + op3;
      if(vid == scratch[3]){
        in = in + op3;
      }
      deg = deg - 1;
      if(deg == 0){
        send_event(cont, 1, in, tot, IGNRCONT);
        yield_terminate;
      }
    }

    if(deg > 0){
      tot = tot + op4;
      if(vid == scratch[4]){
        in = in + op4;
      }
      deg = deg - 1;
      if(deg == 0){
        send_event(cont, 1, in, tot, IGNRCONT);
        yield_terminate;
      }
    }

    if(deg > 0){
      tot = tot + op5;
      if(vid == scratch[5]){
        in = in + op5;
      }
      deg = deg - 1;
      if(deg == 0){
        send_event(cont, 1, in, tot, IGNRCONT);
        yield_terminate;
      }
    }

    if(deg > 0){
      tot = tot + op6;
      if(vid == scratch[6]){
        in = in + op6;
      }
      deg = deg - 1;
      if(deg == 0){
        send_event(cont, 1, in, tot, IGNRCONT);
        yield_terminate;
      }
    }

    if(deg > 0){
      tot = tot + op7;
      if(vid == scratch[7]){
        in = in + op7;
      }
      deg = deg - 1;
      if(deg == 0){
        send_event(cont, 1, in, tot, IGNRCONT);
        yield_terminate;
      }
    }
  }

  event read_neighbor(unsigned long op0, unsigned long op1, unsigned long op2, unsigned long op3, unsigned long op4, unsigned long op5, unsigned long op6, unsigned long op7, unsigned long * _addr){
    unsigned long offset = _addr - neigh_ptr_start;
    unsigned long tmp = offset & (NUM_DRAM_ACCESS * 8 - 1);
    copyOperands(op0, scratch + tmp, 8);
    send_dram_read(weight_ptr_start + offset, 8, read_weight);
  }

  event read_weight(double op0, double op1, double op2, double op3, double op4, double op5, double op6, double op7, unsigned long * _addr){
    unsigned long offset = _addr - weight_ptr_start;
    unsigned long idx = offset >> 3;
    idx = idx + NUM_DRAM_ACCESS;
    if(idx < deg){ //read next 8 words
      idx = idx << 3;
      unsigned long *addr = neigh_ptr_start + idx;
      send_dram_read(addr, 8, read_neighbor);
      idx = idx & (NUM_DRAM_ACCESS * 8 - 1);
      unsigned long *local scratch_tmp = scratch + idx;

      tot = tot + op0;
      if(vid == scratch_tmp[0]){
        in = in + op0;
      }
      tot = tot + op1;
      if(vid == scratch_tmp[1]){
        in = in + op1;
      }
      tot = tot + op2;
      if(vid == scratch_tmp[2]){
        in = in + op2;
      }
      tot = tot + op3;
      if(vid == scratch_tmp[3]){
        in = in + op3;
      }
      tot = tot + op4;
      if(vid == scratch_tmp[4]){
        in = in + op4;
      }
      tot = tot + op5;
      if(vid == scratch_tmp[5]){
        in = in + op5;
      }
      tot = tot + op6;
      if(vid == scratch_tmp[6]){
        in = in + op6;
      }
      tot = tot + op7;
      if(vid == scratch_tmp[7]){
        in = in + op7;
      }
      yield;
    }

    outgoing = outgoing - 1;

    idx = idx - NUM_DRAM_ACCESS;
    offset = offset & (NUM_DRAM_ACCESS * 8 - 1);
    unsigned long *local scratch_tmp = scratch + offset;
    if(deg > idx){
      tot = tot + op0;
      if(vid == scratch_tmp[0]){
        in = in + op0;
      }
      idx = idx + 1;
    }
    if(deg > idx){
      tot = tot + op1;
      if(vid == scratch_tmp[1]){
        in = in + op1;
      }
      idx = idx + 1;
    }

    if(deg > idx){
      tot = tot + op2;
      if(vid == scratch_tmp[2]){
        in = in + op2;
      }
      idx = idx + 1;
    }

    if(deg > idx){
      tot = tot + op3;
      if(vid == scratch_tmp[3]){
        in = in + op3;
      }
      idx = idx + 1;
    }
    if(deg > idx){
      tot = tot + op4;
      if(vid == scratch_tmp[4]){
        in = in + op4;
      }
      idx = idx + 1;
    }
    if(deg > idx){
      tot = tot + op5;
      if(vid == scratch_tmp[5]){
        in = in + op5;
      }
      idx = idx + 1;
    }
    if(deg > idx){
      tot = tot + op6;
      if(vid == scratch_tmp[6]){
        in = in + op6;
      }
      idx = idx + 1;
    }
    if(deg > idx){
      tot = tot + op7;
      if(vid == scratch_tmp[7]){
        in = in + op7;
      }
      idx = idx + 1;
    }
 
    if(outgoing == 0){
      send_event(cont, 1, in, tot, IGNRCONT);
      yield_terminate;
    }
  }
}


        send_event(cont, 1, in, tot, IGNRCONT);
        yield_terminate;
      }
    }

    if(deg > 0){
      tot = tot + op1;
      if(vid == scratch[1]){
        in = in + op1;
      }
      deg = deg - 1;
      if(deg == 0){
        send_event(cont, 1, in, tot, IGNRCONT);
        yield_terminate;
      }
    }

    if(deg > 0){
      tot = tot + op2;
      if(vid == scratch[2]){
        in = in + op2;
      }
      deg = deg - 1;
      if(deg == 0){
        send_event(cont, 1, in, tot, IGNRCONT);
        yield_terminate;
      }
    }

    if(deg > 0){
      tot = tot + op3;
      if(vid == scratch[3]){
        in = in + op3;
      }
      deg = deg - 1;
      if(deg == 0){
        send_event(cont, 1, in, tot, IGNRCONT);
        yield_terminate;
      }
    }

    if(deg > 0){
      tot = tot + op4;
      if(vid == scratch[4]){
        in = in + op4;
      }
      deg = deg - 1;
      if(deg == 0){
        send_event(cont, 1, in, tot, IGNRCONT);
        yield_terminate;
      }
    }

    if(deg > 0){
      tot = tot + op5;
      if(vid == scratch[5]){
        in = in + op5;
      }
      deg = deg - 1;
      if(deg == 0){
        send_event(cont, 1, in, tot, IGNRCONT);
        yield_terminate;
      }
    }

    if(deg > 0){
      tot = tot + op6;
      if(vid == scratch[6]){
        in = in + op6;
      }
      deg = deg - 1;
      if(deg == 0){
        send_event(cont, 1, in, tot, IGNRCONT);
        yield_terminate;
      }
    }

    if(deg > 0){
      tot = tot + op7;
      if(vid == scratch[7]){
        in = in + op7;
      }
      deg = deg - 1;
      if(deg == 0){
        send_event(cont, 1, in, tot, IGNRCONT);
        yield_terminate;
      }
    }
  }

  event read_neighbor(unsigned long op0, unsigned long op1, unsigned long op2, unsigned long op3, unsigned long op4, unsigned long op5, unsigned long op6, unsigned long op7, unsigned long * _addr){
    unsigned long offset = _addr - neigh_ptr_start;
    unsigned long tmp = offset & (NUM_DRAM_ACCESS * 8 - 1);
    copyOperands(op0, scratch + tmp, 8);
    send_dram_read(weight_ptr_start + offset, 8, read_weight);
  }

  event read_weight(double op0, double op1, double op2, double op3, double op4, double op5, double op6, double op7, unsigned long * _addr){
    unsigned long offset = _addr - weight_ptr_start;
    unsigned long idx = offset >> 3;
    idx = idx + NUM_DRAM_ACCESS;
    if(idx < deg){ //read next 8 words
      idx = idx << 3;
      unsigned long *addr = neigh_ptr_start + idx;
      send_dram_read(addr, 8, read_neighbor);
      idx = idx & (NUM_DRAM_ACCESS * 8 - 1);
      unsigned long *local scratch_tmp = scratch + idx;

      // weight_ptr_start = weight_ptr_start + NUM_DRAM_ACCESS * 8;
      // neigh_ptr_start = neigh_ptr_start + NUM_DRAM_ACCESS * 8;

      tot = tot + op0;
      if(vid == scratch_tmp[0]){
        in = in + op0;
      }
      tot = tot + op1;
      if(vid == scratch_tmp[1]){
        in = in + op1;
      }
      tot = tot + op2;
      if(vid == scratch_tmp[2]){
        in = in + op2;
      }
      tot = tot + op3;
      if(vid == scratch_tmp[3]){
        in = in + op3;
      }
      tot = tot + op4;
      if(vid == scratch_tmp[4]){
        in = in + op4;
      }
      tot = tot + op5;
      if(vid == scratch_tmp[5]){
        in = in + op5;
      }
      tot = tot + op6;
      if(vid == scratch_tmp[6]){
        in = in + op6;
      }
      tot = tot + op7;
      if(vid == scratch_tmp[7]){
        in = in + op7;
      }
      yield;
    }

    outgoing = outgoing - 1;

    idx = idx - NUM_DRAM_ACCESS;
    offset = offset & (NUM_DRAM_ACCESS * 8 - 1);
    unsigned long *local scratch_tmp = scratch + offset;
    if(deg > idx){
      tot = tot + op0;
      if(vid == scratch_tmp[0]){
        in = in + op0;
      }
      idx = idx + 1;
    }
    if(deg > idx){
      tot = tot + op1;
      if(vid == scratch_tmp[1]){
        in = in + op1;
      }
      idx = idx + 1;
    }

    if(deg > idx){
      tot = tot + op2;
      if(vid == scratch_tmp[2]){
        in = in + op2;
      }
      idx = idx + 1;
    }

    if(deg > idx){
      tot = tot + op3;
      if(vid == scratch_tmp[3]){
        in = in + op3;
      }
      idx = idx + 1;
    }
    if(deg > idx){
      tot = tot + op4;
      if(vid == scratch_tmp[4]){
        in = in + op4;
      }
      idx = idx + 1;
    }
    if(deg > idx){
      tot = tot + op5;
      if(vid == scratch_tmp[5]){
        in = in + op5;
      }
      idx = idx + 1;
    }
    if(deg > idx){
      tot = tot + op6;
      if(vid == scratch_tmp[6]){
        in = in + op6;
      }
      idx = idx + 1;
    }
    if(deg > idx){
      tot = tot + op7;
      if(vid == scratch_tmp[7]){
        in = in + op7;
      }
      idx = idx + 1;
    }
 
    if(outgoing == 0){
      send_event(cont, 1, in, tot, IGNRCONT);
      yield_terminate;
    }
  }
}
    
    